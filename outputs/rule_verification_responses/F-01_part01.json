  "new_signals": [
    {
      "name": "협조요청·자료제출요청 조문 FP 필터",
      "logic": "조문제목 OR 본문에 '협조요청|자료의 제공.*요청|요청할 수 있다' AND '응하여야 한다|따라야 한다' 존재 AND 침익적 처분(취소·정지·금지) 부재",
      "effect": "FP_FILTER",
      "examples": ["F-01-001@건강검진기본법", "F-01-005@독립유공자예우에관한법률", "F-01-004@공공감사에관한법률"],
      "rationale": "정보·자료 협조요청은 수범자 권리를 직접 박탈하는 침익적 제한이 아니라 행정 협조의무에 그침."
    },
    {
      "name": "벌칙조문에서 잡힌 권리제한 FP",
      "logic": "본문에 '\\d+년 이하의 징역|\\d+(천)?만원 이하의 벌금|벌금|구류|과료' AND 행위규범 부재(제X조를 위반한 자는 …처한다 패턴)",
      "effect": "FP_FILTER",
      "examples": ["F-01-013@외국인투자촉진법", "F-01-002@국립해양생물자원관의설립및운영에관한법률", "F-01-012@국민기초생활보장법"],
      "rationale": "벌칙조문의 '~할 수 없다/처한다'는 제재근거이지 권리제한 결함이 아님(F-01 명시 FP)."
    },
    {
      "name": "근로자·수급권 보호규정 FP",
      "logic": "본문에 '불리한 처우|해고.*아니|차별하여서는 아니|압류할 수 없다|양도하거나 담보' AND 보호대상이 수범자가 아닌 약자(근로자·수급권자)",
      "effect": "FP_FILTER",
      "examples": ["F-01-005@광산안전법", "F-01-027@국민연금법", "F-01-019@국가유산수리등에관한법률", "F-01-003@국립대학법인서울대학교설립ㆍ운영에관한법률"],
      "rationale": "'~할 수 없다'가 권리박탈이 아닌 약자보호(압류금지·차별금지)로 작용 — 침익 아님."
    },
    {
      "name": "처분조 본문(취소·정지) 절차완비 FP",
      "logic": "조문제목에 '취소|정지|인가취소|허가의 취소' AND 본문에 거짓·부정한 방법 등 사유 각 호 ≥3 AND 처분기준 위임(대통령령·부령으로 정한다)",
      "effect": "FP_FILTER",
      "examples": ["F-01-012@감정평가및감정평가사에관한법률", "F-01-004@국민기초생활보장법", "F-01-006@정보통신진흥및융합활성화등에관한특별법"],
      "rationale": "재량처분 사유·기준이 명확하고 시행령 위임으로 구체화 — 구제수단 부재 결함 아님."
    }
  ],
  "missed_patterns": [
    {
      "name": "행위규범 금지(~할 수 없다) + 제재·구제 미연계",
      "logic": "본문 '~할 수 없다|하여서는 아니 된다' AND 같은 법 내 이의신청·청문 조문 참조 부재",
      "examples": ["「결혼중개업의관리에관한법률」 §7", "「재외국민등록법」 §5", "「광업법」 §4"]
    },
    {
      "name": "다른 법 의제로 인한 거래제한 전가",
      "logic": "'~으로 본다|간주' AND 타법(부동산거래신고법 등) 허가구역 의제로 사인 권리 제한",
      "examples": ["「산업입지및개발에관한법률」 §39의2"]
    }
  ]
}
