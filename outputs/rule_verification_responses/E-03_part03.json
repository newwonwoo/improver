"new_signals":[
{"name":"신청·통지 강행의무에 서면 한정 + 전자대안 부재","logic":"'서면으로.{0,15}(신청|신고|통보|통지|제출)하여야' 매칭 AND 동일 조에 '전자|정보통신망|전자문서' 부재","effect":"TP_BOOST","examples":["E-03-002@전사ㆍ순직한진급예정자의진급에관한특별법","E-03-002@지방세법","E-03-001@제주4ㆍ3사건진상규명및희생자명예회복에관한특별법","E-03-001@정보보호산업의진흥에관한법률"],"rationale":"강행 의무규정에서 서면만 허용하면 전자화 차단으로 명확한 아날로그 잔재."},
{"name":"등기촉탁·증명서면 등 등기법 연동 서면","logic":"'등기촉탁|소유권이전등기|등기원인.{0,10}증명' AND ('서면|촉탁서') 동시 매칭","effect":"FP_FILTER","examples":["E-03-001@징발재산정리에관한특별조치법"],"rationale":"부동산등기법 체계에 종속된 증명서면은 단독 전자화 불가, 키워드 오탐."},
{"name":"벌칙·권리의제 조문의 서면키워드","logic":"조문제목 '벌칙|과태료' OR 본문 '벌금에 처한다|~한 것으로 본다' AND (서명|서면) 키워드","effect":"FP_FILTER","examples":["E-03-001@항공사업법","E-03-002@주민등록법","E-03-002@외국인투자촉진법"],"rationale":"제재·의제 조문의 서면키워드는 침익적 절차의무가 아님, FP."}
],
"missed_patterns":[
{"name":"보존의무 매체 미명시","logic":"'(서면|계약서|서류).{0,10}보존하여야' AND 전자보존 허용 명시 부재","examples":["「예술인복지법」 §5의2"]},
{"name":"우편 송달 단일수단","logic":"'우편으로 발송|등기우편' AND 전자송달 대안 부재","examples":["「채무자회생및파산에관한법률」 §240"]}
]}
