{"bundle_id":"G-01_part01","rule_id":"G-01","verdicts":[{"fid":"G-01-003@가축분뇨의관리및이용에관한법률","v":"TP","ev":"중간배출 금지 단서 모호"},{"fid":"G-01-002@건설기술진흥법","v":"TP","ev":"등록취소 단서 분기 중첩"},{"fid":"G-01-004@건설산업기본법","v":"FP","ev":"직접시공 면제 단서 위임"},{"fid":"G-01-004@건축법","v":"TP","ev":"건축허가 단서 9중첩"},{"fid":"G-01-011@건축법","v":"FP","ev":"양벌규정 면책 단서"},{"fid":"G-01-003@고엽제후유의증등환자지원및단체설립에관한법률","v":"TP","ev":"진료제한 단서 다중"},{"fid":"G-01-007@고용보험및산업재해보상보험의보험료징수등에관한법률","v":"BORDER","ev":"노무제공자 보험료 단서"},{"fid":"G-01-002@공유재산및물품관리법","v":"TP","ev":"사용허가기간 단서 중첩"},{"fid":"G-01-001@공인중개사법","v":"TP","ev":"실무교육 면제 단서"},{"fid":"G-01-017@공직선거법","v":"FP","ev":"기부행위 정의 단서"},{"fid":"G-01-011@공직선거법","v":"TP","ev":"공무원 금지 단서 분기"},{"fid":"G-01-007@공직자윤리법","v":"TP","ev":"주식백지신탁 단서"},{"fid":"G-01-018@관세법","v":"FP","ev":"행정소송 준용 단서"},{"fid":"G-01-002@관세법","v":"FP","ev":"과세가격 단서 7중"},{"fid":"G-01-003@관세법","v":"TP","ev":"용도세율 승인 단서"},{"fid":"G-01-003@교육공무원법","v":"FP","ev":"휴직기간 연장 단서"},{"fid":"G-01-001@국가공무원법","v":"FP","ev":"시험위임 단서"},{"fid":"G-01-008@국민건강보험법","v":"BORDER","ev":"외국인 가입 단서"},{"fid":"G-01-011@국세기본법","v":"FP","ev":"행정심판 준용 단서"},{"fid":"G-01-021@국회법","v":"FP","ev":"긴급현안질문 시간 단서"},{"fid":"G-01-005@군인재해보상법","v":"FP","ev":"고의·중과실 면책 단서"},{"fid":"G-01-001@근로복지기본법","v":"BORDER","ev":"우리사주조합 자격 단서"},{"fid":"G-01-001@금융소비자보호에관한법률","v":"FP","ev":"정의조항 제외 단서"},{"fid":"G-01-001@대부업등의등록및금융이용자보호에관한법률","v":"TP","ev":"대부업 등록 면제 단서"},{"fid":"G-01-004@도로교통법","v":"TP","ev":"차로통행 허가 단서"},{"fid":"G-01-018@도시및주거환경정비법","v":"TP","ev":"조정위 기간 연장 단서"},{"fid":"G-01-007@독점규제및공정거래에관한법률","v":"TP","ev":"의결권제한 단서 다중"},{"fid":"G-01-001@독점규제및공정거래에관한법률","v":"TP","ev":"기업결합 예외 단서"},{"fid":"G-01-001@동ㆍ서ㆍ남해안및내륙권발전특별법","v":"BORDER","ev":"개발구역 지정 단서"},{"fid":"G-01-003@디지털의료제품법","v":"TP","ev":"임상시험 승인 단서"},{"fid":"G-01-002@마약류불법거래방지에관한특례법","v":"FP","ev":"형사절차 참가 단서"},{"fid":"G-01-001@물류시설의개발및운영에관한법률","v":"FP","ev":"정의조항 제외 단서"},{"fid":"G-01-001@방문판매등에관한법률","v":"TP","ev":"청약철회 제한 단서"},{"fid":"G-01-026@법인세법","v":"FP","ev":"구분경리 면제 단서"},{"fid":"G-01-021@법인세법","v":"FP","ev":"국내원천소득 정의 단서"},{"fid":"G-01-008@병역법","v":"TP","ev":"복무연장 면제 단서"},{"fid":"G-01-001@보호소년등의처우에관한법률","v":"TP","ev":"면회제한 단서 중첩"},{"fid":"G-01-004@부패방지및국민권익위원회의설치와운영에관한법률","v":"BORDER","ev":"포상·보상 감액 단서"},{"fid":"G-01-001@사립학교교직원연금법","v":"FP","ev":"정의조항 제외 단서"},{"fid":"G-01-036@소득세법","v":"FP","ev":"전자기부금영수증 단서"},{"fid":"G-01-008@소득세법","v":"FP","ev":"결손금공제 단서"},{"fid":"G-01-016@소득세법","v":"FP","ev":"주택임대 감면 단서"},{"fid":"G-01-002@소득세법","v":"FP","ev":"원천징수 납세지 단서"},{"fid":"G-01-002@수산물유통의관리및지원에관한법률","v":"TP","ev":"위판장 매매방법 단서"},{"fid":"G-01-001@수산업협동조합법","v":"FP","ev":"총회의결 인가 단서"},{"fid":"G-01-001@수입식품안전관리특별법","v":"BORDER","ev":"수입위생평가 단서"},{"fid":"G-01-003@시설물의안전및유지관리에관한특별법","v":"TP","ev":"등록취소 단서 중첩"},{"fid":"G-01-007@신용정보의이용및보호에관한법률","v":"FP","ev":"과징금 부과 단서"},{"fid":"G-01-002@신용정보의이용및보호에관한법률","v":"FP","ev":"허가요건 제외 단서"},{"fid":"G-01-001@외국법자문사법","v":"FP","ev":"합작참여자 결격 단서"}],"new_signals":[{"name":"정의조항 단서 FP필터","logic":"조문제목 ~= /정의|용어/ AND 본문 ~= /이 법에서.*뜻은|이라 함은|이란.*말한다/ AND 단서가 '제외/포함/한정' → FP","effect":"FP_FILTER","examples":["G-01-001@금융소비자보호에관한법률","G-01-001@물류시설의개발및운영에관한법률","G-01-001@사립학교교직원연금법","G-01-021@법인세법"],"rationale":"정의조항 단서는 적용범위 명확화 목적이며 권리침해·재량남용과 무관"},{"name":"양벌·면책 단서 FP필터","logic":"조문제목 ~= /양벌규정|벌칙|과태료/ AND 단서 ~= /상당한 주의와 감독|고의가 아닌|정상적인 인식능력/ → FP","effect":"FP_FILTER","examples":["G-01-011@건축법","G-01-005@군인재해보상법"],"rationale":"양벌규정·고의과실 면책단서는 책임주의 원칙상 입법관행"},{"name":"행정심판·소송 준용 단서 FP필터","logic":"조문 ~= /행정심판법|행정소송법.*준용/ AND 단서가 재조사결정·결정기간 분기 → FP","effect":"FP_FILTER","examples":["G-01-018@관세법","G-01-011@국세기본법"],"rationale":"불복절차 준용단서는 절차명확화 목적이며 침익적 재량 아님"},{"name":"처분조문 단서중첩 TP부스트","logic":"조문제목 ~= /등록취소|영업정지|허가취소|면직/ AND 단서 ≥3개 AND '~할 수 있다' 재량 + 단서 분기에 새로운 침익효과 → TP","effect":"TP_BOOST","examples":["G-01-002@건설기술진흥법","G-01-003@시설물의안전및유지관리에관한특별법","G-01-007@공직자윤리법"],"rationale":"처분 재량 단서중첩은 행정절차법상 예측가능성·청문권 침해 우려"},{"name":"기본권관련 절차 면제 단서 TP부스트","logic":"본문이 면회·통신·청약철회·교육·면제·진료 등 기본권 + 단서 ≥3개로 권리·동의·통지 면제 → TP","effect":"TP_BOOST","examples":["G-01-001@보호소년등의처우에관한법률","G-01-001@방문판매등에관한법률","G-01-003@고엽제후유의증등환자지원및단체설립에관한법률","G-01-003@디지털의료제품법"],"rationale":"기본권 영역의 단서중첩은 권익위 규제개혁 권고 빈출 패턴"},{"name":"세제·재정 절차단서 FP필터","logic":"조문이 세법(소득세·법인세·관세·지방세) AND 단서가 '추계조사/기준소득/비치·기록 장부' 등 세무절차 변형 → FP","effect":"FP_FILTER","examples":["G-01-008@소득세법","G-01-016@소득세법","G-01-002@소득세법","G-01-036@소득세법","G-01-026@법인세법"],"rationale":"세무절차 변형 단서는 기술적 재량이며 침익·재량남용 아님"}],"missed_patterns":[{"name":"단서로 본문 의무 무력화","logic":"본문 '~하여야 한다' + 단서 '그러하지 아니하다' AND 단서 적용범위가 본문보다 광범 → 원칙·예외 역전","examples":["「건축법」 §11","「공유재산및물품관리법」 §21","「독점규제및공정거래에관한법률」 §25"]},{"name":"단서 내 재위임(이중위임)","logic":"단서 + '대통령령으로 정하는' 또는 '총리령으로 정하는' 동시 출현 → 단서가 추가위임","examples":["「공직자윤리법」 §14조의4","「디지털의료제품법」 §10","「건설산업기본법」 §28조의2"]},{"name":"단서 분기 후 다시 단서","logic":"호 내부 '다만, ~. 다만, ~' 연쇄 → 가독성·법적안정성 저해","examples":["「건축법」 §11","「독점규제및공정거래에관한법률」 §9","「외국법자문사법」 §35조의8"]},{"name":"제재공백 생성 단서","logic":"금지·처분조항 + 단서 '미리 승인을 받으면 그러하지 아니하다' AND 승인기준 부재 → 회피 우려","examples":["「관세법」 §83","「가축분뇨의관리및이용에관한법률」 §25","「도로교통법」 §14"]},{"name":"단서 누적 (4회 이상)","logic":"한 조문 내 단서 ≥4회 AND 각 단서가 서로 다른 효과영역 → 입법기술상 분리 필요","examples":["「건축법」 §11","「공직선거법」 §86","「관세법」 §30"]}]}
