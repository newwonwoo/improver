  "new_signals": [
    {
      "name": "목적조문 단독매칭 FP필터",
      "logic": "조문제목이 '목적|설치|통칙' AND 본문에 '이 법은.*목적으로 한다' AND 처분/의무/제재 키워드 부재 → FP",
      "effect": "FP_FILTER",
      "examples": ["G-04-001@한국가스공사법", "G-04-001@선박투자회사법", "G-04-001@정부법무공단법", "G-04-001@한국관광공사법"],
      "rationale": "목적조문은 입법취지 선언이며 내부통제 5요소를 담을 자리가 아님. G-04는 실체조문(임원·감사·이사회·내부통제기준)에 적용되어야 함."
    },
    {
      "name": "폐지법령 매칭 FP",
