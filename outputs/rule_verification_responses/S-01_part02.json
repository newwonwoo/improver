"new_signals":[
{"name":"임계 근접(<40%) 경고·주의 등급 일괄 FP 다운","logic":"삽입조비율 < 0.40 AND severity in {경고,주의} AND 본문이 정의/계획/기구/기념일/노력의무 중 하나 -> FP_FILTER","effect":"FP_FILTER","examples":["S-01-001@공공기관의운영에관한법률","S-01-001@감사원법","S-01-001@군인사법","S-01-001@무역보험법"],"rationale":"part02는 전부 40% 미만 경고/주의로 임계 근접이며 콘텐츠가 비침익 조문이라 결함 신뢰도 낮음."},
{"name":"기념일/주간 지정 조문 FP 필터(재확인)","logic":"제목/본문에 /(\\S+)의 ?날|주간|기념일/ AND /북돋우|자긍심|취지에 맞는 행사/ -> FP_FILTER","effect":"FP_FILTER","examples":["S-01-001@자전거이용활성화에관한법률","S-01-001@제대군인지원에관한법률","S-01-001@장애인ㆍ노인ㆍ임산부등의편의증진보장에관한법률"],"rationale":"기념일·주간 지정 조문은 정책선언으로 삽입조 비율이 결함 신호가 아님."},
{"name":"내부조직/위원회 규칙·정관 위임 FP 필터","logic":"본문에 /분과위원회|판사회의|부설기관|연합협의회|심의위원회/ AND /감사원규칙|대법원규칙|정관|대통령령으로 정한다/ AND 처분키워드 부재 -> FP_FILTER","effect":"FP_FILTER","examples":["S-01-001@감사원법","S-01-001@법원조직법","S-01-001@한국과학기술원법","S-01-001@축산물위생관리법"],"rationale":"내부조직 구성·운영 위임은 침익성 없는 조직규정."},
{"name":"본문 결손(제목만) 조문 BORDER/제외","logic":"조문 본문이 /^제\\S+조의\\d+\\([^)]+\\)$/ 제목 1줄뿐 -> 검증불가 BORDER","effect":"FP_FILTER","examples":["S-01-001@상가건물임대차보호법","S-01-001@국민기초생활보장법"],"rationale":"본문이 비어 콘텐츠 판정 자체가 불가하므로 룰 매칭만으로 결함 단정 불가."},
{"name":"제재조문이라도 사전통지·소명기회 포함시 FP","logic":"제목에 /제재|부정행위|조치/ AND 본문에 /소명할 기회|미리.*통지|사전통지/ -> FP_FILTER","effect":"FP_FILTER","examples":["S-01-001@항만운송사업법","S-01-001@행정사법"],"rationale":"제재조문에 사전통지·소명절차가 명시돼 절차적 흠결이 없음."}
],
"missed_patterns":[
{"name":"시행령 ±3조에 구체 호 다수 존재시 위임공백 부정","logic":"법조문 위임키워드 AND 시행령 매핑 ±3조에 /각 호|제\\d+호/ >= 3 -> S-02 위임 FP 교차신호","examples":["「농어업재해보험법」 §2의2","「영재교육진흥법」 §4의2","「건축법」 §4의2"]},
{"name":"세율·보상 등 수익적 재량의 차등기준 모호","logic":"/세율|보상금|장려금|환수/ AND /대통령령으로 정하는/ AND 구체 차등기준 본문 부재 -> 명확성 점검(별도 룰)","examples":["「개별소비세법」 §1의2","「국가과학기술경쟁력강화를위한이공계지원특별법」 §9의2"]},
{"name":"명칭사용 제한 등 장기 권리제한 기간의 비례성","logic":"/동일한 명칭.*받을 수 없다/ AND /10년|5년이 지나지 아니한/ -> 제한기간 비례성 점검","examples":["「경비업법」 §4의2"]}
]
}
