{"bundle_id":"G-01_part02","rule_id":"G-01","verdicts":[{"fid":"G-01-001@위치정보의보호및이용등에관한법률","v":"TP","ev":"긴급구조 단서 다중·동의예외"},{"fid":"G-01-035@자본시장과금융투자업에관한법률","v":"FP","ev":"특례조문·준용단서"},{"fid":"G-01-004@자본시장과금융투자업에관한법률","v":"FP","ev":"상호규제 단서는 예외허용"},{"fid":"G-01-003@장기등이식에관한법률","v":"TP","ev":"동의예외 단서 중첩"},{"fid":"G-01-027@조세특례제한법","v":"FP","ev":"준용·인용 단서 다수"},{"fid":"G-01-001@지방공무원법","v":"BORDER","ev":"인사위 구성 단서 분기"},{"fid":"G-01-018@지방세법","v":"FP","ev":"환급절차 준용 단서"},{"fid":"G-01-007@지방세법","v":"TP","ev":"세율특례 단서 5중첩"},{"fid":"G-01-010@지방세특례제한법","v":"FP","ev":"감면대상 정의 단서"},{"fid":"G-01-001@지방재정법","v":"BORDER","ev":"특별회계 설치 단서"},{"fid":"G-01-020@채무자회생및파산에관한법률","v":"TP","ev":"인가효력 단서 중첩"},{"fid":"G-01-001@채용절차의공정화에관한법률","v":"TP","ev":"반환의무 단서 3회"},{"fid":"G-01-003@취업후학자금상환특별법","v":"BORDER","ev":"상환의무 단서 분기"},{"fid":"G-01-007@측량ㆍ수로조사및지적에관한법률","v":"TP","ev":"출입권 단서 3회"},{"fid":"G-01-012@특허법","v":"FP","ev":"단순 효력범위 규정"},{"fid":"G-01-001@학생맞춤통합지원법","v":"BORDER","ev":"센터 설치 단서"},{"fid":"G-01-005@항공사업법","v":"TP","ev":"등록취소 단서 분기"},{"fid":"G-01-011@항공안전법","v":"FP","ev":"벌칙조문 단서"},{"fid":"G-01-003@해양이용영향평가법","v":"FP","ev":"과태료 제외 단서"},{"fid":"G-01-002@해양조사와해양정보활용에관한법률","v":"TP","ev":"지정취소 단서 중첩"},{"fid":"G-01-004@환경오염시설의통합관리에관한법률","v":"TP","ev":"운영금지 단서 다중"},{"fid":"G-01-001@5ㆍ18민주유공자예우및단체설립에관한법률","v":"FP","ev":"단순 위임규정"},{"fid":"G-01-006@가맹사업거래의공정화에관한법률","v":"FP","ev":"고의과실 단서 입법관행"},{"fid":"G-01-001@가맹사업거래의공정화에관한법률","v":"BORDER","ev":"등록·신고 단서"},{"fid":"G-01-002@가축전염병예방법","v":"TP","ev":"소독설비 단서 의무분기"},{"fid":"G-01-005@가축전염병예방법","v":"TP","ev":"살처분명령 단서 중첩"},{"fid":"G-01-004@간선급행버스체계의건설및운영에관한특별법","v":"FP","ev":"과태료 단서 관행"},{"fid":"G-01-001@감정평가및감정평가사에관한법률","v":"FP","ev":"결격사유 단서"},{"fid":"G-01-002@건강기능식품에관한법률","v":"BORDER","ev":"영업허가제한 단서"},{"fid":"G-01-003@건축법","v":"FP","ev":"절차기한 연장 단서"},{"fid":"G-01-001@건축서비스산업진흥법","v":"BORDER","ev":"심의위 설치 단서"},{"fid":"G-01-003@고준위방사성폐기물관리에관한특별법","v":"FP","ev":"양벌규정 단서"},{"fid":"G-01-002@골재채취법","v":"TP","ev":"영업정지 단서 잔여허용"},{"fid":"G-01-004@공유재산및물품관리법","v":"BORDER","ev":"대부기간 단서"},{"fid":"G-01-025@공직선거법","v":"TP","ev":"개표공표 단서 보도예외"},{"fid":"G-01-011@공직자윤리법","v":"FP","ev":"신고자보호 단서"},{"fid":"G-01-001@공항소음방지및소음대책지역지원에관한법률","v":"FP","ev":"부담금 면제 열거"},{"fid":"G-01-008@관광진흥법","v":"BORDER","ev":"의제 단서 분기"},{"fid":"G-01-012@관세법","v":"FP","ev":"감면 단서 외법 인용"},{"fid":"G-01-017@관세법","v":"FP","ev":"준용규정 단서"},{"fid":"G-01-020@관세법","v":"TP","ev":"입항보고 단서 생략권"},{"fid":"G-01-024@관세법","v":"TP","ev":"폐기 단서 통고예외"},{"fid":"G-01-026@관세법","v":"FP","ev":"보관책임 단서 비용"},{"fid":"G-01-027@관세법","v":"FP","ev":"결격사유 단서"},{"fid":"G-01-028@관세법","v":"TP","ev":"특허비율 단서 중첩"},{"fid":"G-01-036@관세법","v":"FP","ev":"과태료 단서 관행"},{"fid":"G-01-037@관세법","v":"FP","ev":"몰수 단서 열거예외"},{"fid":"G-01-001@교육공무원법","v":"BORDER","ev":"공모임용 단서"},{"fid":"G-01-004@교육공무원법","v":"FP","ev":"벌칙 면책단서"},{"fid":"G-01-003@국가공무원법","v":"TP","ev":"직권면직 단서 동의요건"}],"new_signals":[{"name":"벌칙·양벌규정 단서 FP필터","logic":"조문제목 ~= /벌칙|양벌규정|과태료|몰수/ AND 단서 내용 ~= /고의|과실|상당한 주의와 감독|진실한 사실/ → FP","effect":"FP_FILTER","examples":["G-01-011@항공안전법","G-01-003@고준위방사성폐기물관리에관한특별법","G-01-004@교육공무원법","G-01-036@관세법","G-01-037@관세법"],"rationale":"벌칙·양벌규정 단서는 책임주의 원칙상 면책사유 명시가 입법관행이며 결함 아님"},{"name":"단순효력범위·정의 단서 FP필터","logic":"조문 본문이 ≤2항 AND 단서가 '대상물건/용도/효력범위/면제' 한정 + 처분·재량 부재 → FP","effect":"FP_FILTER","examples":["G-01-012@특허법","G-01-001@5ㆍ18민주유공자예우및단체설립에관한법률","G-01-001@공항소음방지및소음대책지역지원에관한법률","G-01-017@관세법"],"rationale":"순수 효력·범위 한정 단서는 침익적 재량과 무관"},{"name":"처분조문 단서중첩 TP부스트","logic":"조문제목 ~= /취소|정지|면직|살처분|폐기명령/ AND 단서 ≥3개 AND '~할 수 있다' 재량 + 사전통지·청문 부재 → TP_BOOST","effect":"TP_BOOST","examples":["G-01-002@해양조사와해양정보활용에관한법률","G-01-005@항공사업법","G-01-003@국가공무원법","G-01-005@가축전염병예방법","G-01-024@관세법"],"rationale":"처분 재량과 단서 중첩은 행정절차법상 예측가능성·방어권 침해 우려"},{"name":"준용·인용 다중 단서 FP필터","logic":"본문에 '~을 준용' OR 외부법령 인용 ≥3개 AND 단서가 준용단서 → FP","effect":"FP_FILTER","examples":["G-01-035@자본시장과금융투자업에관한법률","G-01-027@조세특례제한법","G-01-018@지방세법","G-01-017@관세법"],"rationale":"준용 단서는 적용범위 명확화 목적이며 결함 아님"},{"name":"권리예외 단서 TP부스트","logic":"단서 ≥3개 AND 동의·통지·청문·반환 등 절차권 면제 ~= /동의 없이|통지하지 아니|즉시 통보 예외/ → TP","effect":"TP_BOOST","examples":["G-01-001@위치정보의보호및이용등에관한법률","G-01-003@장기등이식에관한법률","G-01-001@채용절차의공정화에관한법률","G-01-007@측량ㆍ수로조사및지적에관한법률"],"rationale":"기본권 관련 절차 예외 중첩은 권익위 규제개혁 권고 대상"}],"missed_patterns":[{"name":"단서내 재위임","logic":"단서 + '대통령령으로 정하는' 동시 출현 → 단서 자체가 추가위임 (이중위임)","examples":["「자본시장과금융투자업에관한법률」 §249조의8","「조세특례제한법」 §87","「관세법」 §176조의2"]},{"name":"단서로 본문 무력화","logic":"본문 의무규정 + 단서 '그러하지 아니하다' AND 단서가 본문보다 광범위 → 원칙·예외 역전","examples":["「공유재산및물품관리법」 §31","「공직선거법」 §178","「채무자회생및파산에관한법률」 §615"]},{"name":"단서 연쇄","logic":"하나의 호 내부에 단서 + 그 단서의 단서(중첩) → 가독성·법적안정성 저해","examples":["「장기등이식에관한법률」 §22③","「위치정보의보호및이용등에관한법률」 §29②","「항공사업법」 §40①"]},{"name":"단서로 제재공백 생성","logic":"제재·금지조항 + 단서 '제외/그러하지 아니하다' AND 제외사유 모호 → 회피 우려","examples":["「환경오염시설의통합관리에관한법률」 §21","「가축전염병예방법」 §17","「해양이용영향평가법」 §54"]}]}
