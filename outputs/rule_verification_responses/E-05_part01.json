"new_signals":[
{"name":"기관내부 보고·작성의무 FP필터","logic":"주어가 '장관/위원회/공단/중앙관서의 장' AND 목적어가 '보고서/계획/대장/회계' AND 상대방이 상급기관·내부기관 → FP","effect":"FP_FILTER","examples":["E-05-024@공공기관의운영에관한법률","E-05-003@가축및축산물이력관리에관한법률","E-05-013@국고금관리법","E-05-009@공공기관의운영에관한법률"],"rationale":"기관 내부 행정의무는 통상 벌칙이 아닌 인사·감사 통제로 담보되므로 제재공백 아님."},
{"name":"절차법 송달·통지·발급 FP필터","logic":"조문 제목/본문에 '송달|통지|발급|기재|촉탁|재결' AND 행위주체가 법원·위원회·세무공무원 → 절차법 제재공백 FP","effect":"FP_FILTER","examples":["E-05-016@공익사업을위한토지등의취득및보상에관한법률","E-05-013@공장및광업재단저당법","E-05-069@관세법","E-05-040@공직선거법"],"rationale":"절차이행 자체에는 벌칙이 없고 처분 효력·불복으로 통제됨."},
{"name":"정책의무(계획수립·홍보·진흥) FP필터","logic":"'계획을 수립ㆍ시행하여야|홍보하여야|양성|활성화|육성' AND 수범자가 국가·지자체 → 정책의무 FP","effect":"FP_FILTER","examples":["E-05-008@국가유산기본법","E-05-006@개발도상국산림을통한온실가스배출감축및탄소축적증진지원에관한법률","E-05-002@공공토지의비축에관한법률","E-05-002@관상어산업의육성및지원에관한법률"],"rationale":"정책·진흥 의무는 본질상 제재대상이 아니며 룰이 키워드로 오탐."},
{"name":"사인 신고·신청 의무 TP부스트","logic":"수범자가 사인('납세의무자|골재채취업자|자') AND '신고하여야|신청하여야' AND 조문에 과태료·벌칙 미연결 → TP","effect":"TP_BOOST","examples":["E-05-003@골재채취법","E-05-005@관세법"],"rationale":"사인에 부과된 신고의무는 실효성 담보 위해 제재가 통상 필요, 진정 제재공백 후보."}
],
"missed_patterns":[
{"name":"협조의무에 정당한사유 단서만 있고 제재 없음","logic":"'정당한 사유가 없으면 협조하여야|따라야' 패턴이나 위반시 효과 미규정","examples":["「결핵예방법」 §25","「교육관련기관의정보공개에관한특례법」 §10의2"]},
{"name":"기한 명시 의무인데 지연효과 미규정","logic":"'N일/N개월 이내에 ~하여야 한다' AND 기한도과 효과 부재","examples":["「1959년12월31일이전에퇴직한군인의퇴직급여금지급에관한특별법」 §7","「갯벌및그주변지역의지속가능한관리와복원에관한법률」 §34"]}
]}
