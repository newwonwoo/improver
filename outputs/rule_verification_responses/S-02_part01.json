"new_signals":[
{"name":"과태료·제재 부과징수 절차 위임은 정상","logic":"조문제목 OR 본문 ~/과태료|징역|벌금/ AND 위임문구 ~/부과ㆍ?징수.*대통령령|대통령령.*부과ㆍ?징수/ → FP","effect":"FP_FILTER","examples":["S-02-019@국가유공자등단체설립에관한법률","S-02-085@국민건강보험법","S-02-051@신용협동조합법","S-02-013@모빌리티혁신및활성화지원에관한법률"],"rationale":"과태료 부과·징수 방법을 시행령에 위임하는 것은 입안 표준양식으로, 위임 미이행 결함이 아니다."},
{"name":"위원회·기관 구성·운영 위임은 통상위임","logic":"본문 ~/위원회|센터|협회|기관/ AND 말미 위임 ~/구성[\\s및ㆍ]*(및)?\\s*운영.*필요한 사항.*(대통령령|총리령)/ → FP","effect":"FP_FILTER","examples":["S-02-025@건강기능식품에관한법률","S-02-028@발명진흥법","S-02-008@경영지도사및기술지도사에관한법률","S-02-020@급경사지재해예방에관한법률"],"rationale":"조직 구성·운영의 세부를 하위법령에 맡기는 것은 헌법상 허용되는 통상 위임으로 침익성이 없다."},
{"name":"수익적·지원적 재량 위임","logic":"본문 ~/지원|보조금|포상|감면|급여|육성|진흥/ AND 위임어 동일조 → 침익 아님 → FP","effect":"FP_FILTER","examples":["S-02-029@사회기반시설에대한민간투자법","S-02-036@게임산업진흥에관한법률","S-02-185@약사법","S-02-045@5ㆍ18민주유공자예우및단체설립에관한법률"],"rationale":"수익적 처분의 세부기준 위임은 권리제한이 아니므로 위임검증 결함 대상이 아니다."},
{"name":"침익적 처분조 + 핵심요건 백지위임","logic":"본문 ~/제한하여야|정지|취소|명하여야|금지/ AND 처분요건 ~/대통령령으로 정하는 (사유|바)/ AND 본문에 구체 요건 호 부재 → TP_BOOST","effect":"TP_BOOST","examples":["S-02-024@사회기반시설에대한민간투자법","S-02-023@해수욕장의이용및관리에관한법률","S-02-038@선박평형수(船舶平衡水)관리법"],"rationale":"침익적 자격제한·이용제한의 핵심 사유를 본문에 두지 않고 통째로 위임하면 포괄위임금지 소지가 있어 부스트해야 한다."}
],
"missed_patterns":[
{"name":"부령·총리령 위임을 시행령 미확인으로 오탐","logic":"위임어가 대통령령이 아닌 부령/총리령/공동부령이면 시행령 매핑 자체가 부적절 → 매칭 제외","examples":["「갯벌및그주변지역의지속가능한관리와복원에관한법률」 §29④","「디자인보호법」 §80②","「농수산물품질관리법」 §80③"]},
{"name":"조례 위임 특례조","logic":"본문 ~/도조례로 정할 수 있다|조례로 정한다/ → 시행령 위임 아님, 매칭 제외","examples":["「강원특별자치도설치및미래산업글로벌도시조성을위한특별법」 §48","「자동차관리법」 §53③"]}
]}
