  "new_signals": [
    {
      "name": "목적조문 FP 필터",
      "logic": "조문제목 == '목적' AND 본문에 정규식 '이바지함을 목적으로 한다|기여함을 목적으로 한다' AND 본문 길이 < 400자 → 5요소 미충족 판정 무력화",
      "effect": "FP_FILTER",
      "examples": ["G-04-001@한국은행법", "G-04-001@한국전력공사법", "G-04-001@협동조합기본법", "G-04-001@한국환경공단법"],
      "rationale": "법제처 입안길잡이상 목적조문은 선언규정이므로 내부통제 5요소를 갖출 수 없음. 룰은 모든 조문에 일괄 적용되어 대규모 FP 발생."
    },
    {
      "name": "폐지·준용 단일조문 FP 필터",
      "logic": "본문 정규식 '이를 폐지한다|준용한다' AND 항·호 구조 없음(단일 문장) → G-04 비적용",
      "effect": "FP_FILTER",
      "examples": ["G-04-001@한국철도공사법", "G-04-001@한국통화안정증권법", "G-04-001@자본시장과금융투자업에관한법률"],
      "rationale": "폐지법·준용조문에 5요소를 요구하는 것은 입법체계 오류."
    },
    {
      "name": "내부통제기준 명시조문 TP 부스트",
      "logic": "조문 본문에 정규식 '내부통제기준|내부통제장치|내부통제시스템|준법감시인' AND '정하여야 한다|마련하여야 한다|두어야 한다' 동시 출현 → TP 강화 (5요소 미충족이어도 핵심 제도 명시이므로 룰 매칭 정당)",
      "effect": "TP_BOOST",
      "examples": ["G-04-001@농업협동조합법", "G-04-001@수산업협동조합법", "G-04-001@신용협동조합법", "G-04-001@한국투자공사법", "G-04-001@금융소비자보호에관한법률"],
      "rationale": "내부통제기준 설치의무 조문은 G-04 룰의 정중앙 적용 대상."
    },
    {
      "name": "5요소 0/5 + 목적조문 동시조건 → FP",
      "logic": "5요소 score == 0 AND (조문제목 contains '목적' OR 정규식 '이바지함을 목적') → 자동 FP 다운그레이드",
      "effect": "FP_FILTER",
      "examples": ["G-04-001@한국토지주택공사법", "G-04-001@한국조폐공사법", "G-04-001@한국주택금융공사법", "G-04-001@한국해양교통안전공단법"],
      "rationale": "목적조문은 본질적으로 정책선언으로 5요소 0/5는 결함이 아닌 입법형식."
    },
    {
      "name": "5요소 부분충족(1~2/5) + 비목적조문 → BORDER → TP",
      "logic": "5요소 score in [1,2] AND 조문제목 not in ['목적','적용범위','정의'] AND 본문에 '내부통제|준법|감사' 포함 → 정밀검토 대상",
      "effect": "NEW_RULE",
      "examples": ["G-04-001@금융복합기업집단의감독에관한법률", "G-04-001@부동산투자회사법", "G-04-001@전자금융거래법"],
      "rationale": "실체조문에서 일부 요소만 갖춘 경우야말로 실질적 G-04 결함이며 보강대상."
    },
    {
      "name": "공공기관 설립근거법 목적조문 일괄 제외",
      "logic": "법률명 정규식 '.*공사법$|.*공단법$|.*재단설립.*법$|.*기금법$' AND 조문 == 제1조(목적) → G-04 비적용 (개별 운영조문 대상)",
      "effect": "FP_FILTER",
      "examples": ["G-04-001@한국전력공사법", "G-04-001@항만공사법", "G-04-001@기술보증기금법", "G-04-001@동북아역사재단설립ㆍ운영에관한법률"],
      "rationale": "설립근거법 목적조문은 5요소 측정 대상이 아니며 본 룰은 운영·감독조문에 한정해야 함."
    }
  ],
