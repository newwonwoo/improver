  "new_signals": [
    {
      "name": "목적조문 자동 FP 필터",
      "logic": "article_title in {'목적','(목적)','((목적))'} OR article_number == '제1조' AND body matches r'이 법은.*함을 목적으로 한다\\.?$' → G-04 FP_FILTER",
      "effect": "FP_FILTER",
      "examples": ["G-04-001@고용보험법", "G-04-001@국민건강보험법", "G-04-001@보험업법", "G-04-001@금융위원회의설치등에관한법률"],
      "rationale": "목적 조문은 법의 입법취지 선언이며 그 자체가 운영조직의 내부통제 5요소(통제환경/위험평가/통제활동/정보소통/모니터링)를 구비할 수 없는 추상 규범. 법제처 입안길잡이상 목적조문은 행위·체계 규정이 아님."
    },
    {
      "name": "기금설치ㆍ공단설립법 단일조문 FP 필터",
      "logic": "law_title matches r'.*(기금법|공단법|공사법|특별법)$' AND article_number == '제1조' AND body contains ('설치','설립') AND NOT contains_any(['내부통제','준법감시','이해상충','위험관리']) → FP_FILTER",
      "effect": "FP_FILTER",
      "examples": ["G-04-001@공공자금관리기금법", "G-04-001@가덕도신공항건설공단법", "G-04-001@대한석탄공사법", "G-04-001@군인복지기금법"],
      "rationale": "기금/공단 설치근거법의 목적조항만 보고 내부통제 5요소 미충족이라 판정하면 모든 설치법이 결함. 실제 통제장치는 본문 운영·관리 조문(자산운용·이사회·감사) 또는 시행령에 위치."
    },
    {
      "name": "내부통제 진성 신호 — 본문 명시키워드",
      "logic": "body contains_any(['내부통제장치','준법감시인','이해상충관리','위험관리체계','준법감시기준']) AND article_number != '제1조' → TP_BOOST",
      "effect": "TP_BOOST",
      "examples": ["G-04-001@금융거래지표의관리에관한법률"],
      "rationale": "G-04는 5요소 키워드 매칭이 아니라 '내부통제장치 의무화 조문에 5요소 중 누락된 요소' 검사가 본질. 본문에 명시적 내부통제 키워드가 있는 조문만 TP 후보."
    },
    {
      "name": "다른 법 인용형 조문 FP",
      "logic": "body matches r'「[^」]+」(에 따른|에 따라|에도 불구하고)' AND article_number == '제1조' → FP_FILTER",
      "effect": "FP_FILTER",
      "examples": ["G-04-001@교원의노동조합설립및운영등에관한법률", "G-04-001@공무원의노동조합설립및운영등에관한법률", "G-04-001@공공기관지방이전에따른혁신도시건설및지원에관한특별법"],
      "rationale": "다른 법령의 특례·후속법인 경우 통제체계는 모법에 위치. 후속법 제1조만 보고 내부통제 부재 판정 불가."
    },
    {
      "name": "법령 단위 적용 — 조문 단위 부적합",
      "logic": "G-04 (내부통제 5요소)는 law_level 또는 chapter_level 집계가 정상. article_level 적용 시 모든 제1조가 0/5 매칭 → 무의미한 알람 양산. rule_scope = 'law' 로 재설계 권고",
      "effect": "NEW_RULE",
      "examples": ["G-04-001@보험업법", "G-04-001@금융위원회의설치등에관한법률"],
      "rationale": "내부통제 5요소(COSO)는 조직 단위 평가 프레임워크. 법령 단위로 ['통제환경','위험평가','통제활동','정보소통','모니터링'] 키워드 분포를 본 뒤 ≤1개 충족 시에만 경보."
    },
    {
      "name": "정책의무·진흥·촉진·육성 목적법 FP",
      "logic": "body contains_any(['진흥','촉진','육성','이바지','발전','도모']) AND NOT contains_any(['감독','검사','제재','내부통제','책임']) → FP_FILTER",
      "effect": "FP_FILTER",
      "examples": ["G-04-001@금융혁신지원특별법", "G-04-001@벤처투자촉진에관한법률", "G-04-001@산업기술연구조합육성법", "G-04-001@관광진흥개발기금법"],
      "rationale": "정책의무·진흥형 법령은 시행 의무가 아니라 시책 근거. 내부통제 5요소 평가 대상 아님 (시스템 프롬프트 FP 기준 직접 해당)."
    }
  ],
