{"bundle_id":"L-01_part03","rule_id":"L-01","verdicts":[{"fid":"L-01-002@공직자윤리법","v":"FP","ev":"금융실명·신용정보·개인정보 예외열거"},{"fid":"L-01-001@공항소음방지및소음대책지역지원에관한법률","v":"FP","ev":"시행자 자격조항 — 인용 불가피"},{"fid":"L-01-001@과세자료의제출및관리에관한법률","v":"FP","ev":"제출기관 범위 열거"},{"fid":"L-01-001@과학관의설립ㆍ운영및육성에관한법률","v":"FP","ev":"인허가의제 조항 — 열거 불가피"},{"fid":"L-01-001@과학기술기본법","v":"FP","ev":"기금 재원·용도 열거"},{"fid":"L-01-005@관광진흥법","v":"BORDER","ev":"실체조항에 인용 다수"},{"fid":"L-01-001@관세법","v":"BORDER","ev":"내국세 적용순위 — 9개"},{"fid":"L-01-001@교원의지위향상및교육활동보호를위한특별법","v":"BORDER","ev":"학생조치 + 형법·성폭법 인용"},{"fid":"L-01-002@교육환경보호에관한법률","v":"FP","ev":"평가서 제출의무자 범위 열거"},{"fid":"L-01-003@교통시설특별회계법","v":"FP","ev":"세입·세출 계정 열거"},{"fid":"L-01-006@교통시설특별회계법","v":"FP","ev":"항만계정 세입·세출 열거"},{"fid":"L-01-001@국가과학기술경쟁력강화를위한이공계지원특별법","v":"FP","ev":"정의조항 — 대학·연구기관"},{"fid":"L-01-003@국가유공자등예우및지원에관한법률","v":"FP","ev":"중복가점 방지 — 타법 인용 필수"},{"fid":"L-01-003@국가자원안보특별법","v":"BORDER","ev":"벌칙조 + 타법 죄형 분기"},{"fid":"L-01-002@국가전략기술육성에관한특별법","v":"FP","ev":"다른 계획과의 조화 — 열거"},{"fid":"L-01-002@국가첨단전략산업경쟁력강화및보호에관한특별조치법","v":"FP","ev":"부담금 감면 — 근거법 열거"},{"fid":"L-01-004@국가첨단전략산업경쟁력강화및보호에관한특별조치법","v":"FP","ev":"특성화대학 범위 열거"},{"fid":"L-01-002@국가통합교통체계효율화법","v":"FP","ev":"다른 계획과의 관계 열거"},{"fid":"L-01-004@국민연금법","v":"FP","ev":"납부예외 사유 — 타법 신분"},{"fid":"L-01-002@국민평생직업능력개발법","v":"FP","ev":"학점인정 근거 열거"},{"fid":"L-01-001@국세기본법","v":"FP","ev":"정의조항 — 세법 열거"},{"fid":"L-01-006@국세기본법","v":"BORDER","ev":"가산세 계산 실체조항"},{"fid":"L-01-007@국세기본법","v":"FP","ev":"가산세 한도 적용대상 열거"},{"fid":"L-01-004@국세징수법","v":"FP","ev":"배분순위 — 우선변제권 인용"},{"fid":"L-01-001@국제조세조정에관한법률","v":"FP","ev":"정의조항 — 해외금융계좌"},{"fid":"L-01-001@국제회의산업육성에관한법률","v":"FP","ev":"부담금 감면 근거법 열거"},{"fid":"L-01-001@군사법원법","v":"FP","ev":"직무범위 죄목 열거"},{"fid":"L-01-003@군인사법","v":"FP","ev":"징계부가금 대상 재산 열거"},{"fid":"L-01-001@궤도운송법","v":"FP","ev":"적용제외 범위 열거"},{"fid":"L-01-002@금융복합기업집단의감독에관한법률","v":"BORDER","ev":"명령조치 + 업권별 분기"},{"fid":"L-01-003@금융산업의구조개선에관한법률","v":"BORDER","ev":"주식소유한도 실체조항"},{"fid":"L-01-003@금융소비자보호에관한법률","v":"FP","ev":"광고 가능 협회등 열거"},{"fid":"L-01-001@금융회사의지배구조에관한법률","v":"FP","ev":"정의조항 — 금융회사 범위"},{"fid":"L-01-008@기업활동규제완화에관한특별조치법","v":"FP","ev":"검사면제 근거법 열거"},{"fid":"L-01-002@기초연구진흥및기술개발지원에관한법률","v":"FP","ev":"연구수행기관 범위 열거"},{"fid":"L-01-001@기후변화대응기술개발촉진법","v":"FP","ev":"공무원 의제 조항 — 단문"},{"fid":"L-01-001@기후위기대응을위한탄소중립ㆍ녹색성장기본법","v":"FP","ev":"정의조항"},{"fid":"L-01-005@낙동강수계물관리및주민지원등에관한법률","v":"BORDER","ev":"허가제한 실체조항 — 인용집중"},{"fid":"L-01-001@낙동강수계물관리및주민지원등에관한법률","v":"FP","ev":"정의조항"},{"fid":"L-01-001@남녀고용평등과일ㆍ가정양립지원에관한법률","v":"BORDER","ev":"가족돌봄 실체조항 + 타법"},{"fid":"L-01-002@노후거점산업단지의활력증진및경쟁력강화를위한특별법","v":"FP","ev":"전략계획 고려대상 열거"},{"fid":"L-01-002@녹색건축물조성지원법","v":"FP","ev":"지원·조세특례 근거 열거"},{"fid":"L-01-001@녹색융합클러스터의조성및육성에관한법률","v":"FP","ev":"실험원료 공급주체·준수규정"},{"fid":"L-01-002@농림수산식품투자조합결성및운용에관한법률","v":"FP","ev":"투자조합 결성자격 열거"},{"fid":"L-01-001@농어촌구조개선특별회계법","v":"FP","ev":"특별회계 세입·세출 열거"},{"fid":"L-01-003@농촌공간재구조화및재생지원에관한법률","v":"FP","ev":"부담금 감면 근거법 열거"},{"fid":"L-01-002@대구경북통합신공항건설을위한특별법","v":"FP","ev":"우선적용 예외계획 열거"},{"fid":"L-01-003@대기환경보전법","v":"BORDER","ev":"과징금 대상시설 + 타법"},{"fid":"L-01-002@대중교통의육성및이용촉진에관한법률","v":"FP","ev":"카드설치 의무자 열거"},{"fid":"L-01-003@대중교통의육성및이용촉진에관한법률","v":"FP","ev":"부담금 감면 근거법 열거"}],"new_signals":[{"name":"정의조항_다중인용_FP필터","logic":"조문제목이 '정의' AND 본문에 '말한다|뜻은 다음과 같다' AND 「」인용≥5 → FP","effect":"FP_FILTER","examples":["L-01-001@국가과학기술경쟁력강화를위한이공계지원특별법","L-01-001@국세기본법","L-01-001@국제조세조정에관한법률","L-01-001@금융회사의지배구조에관한법률","L-01-001@기후위기대응을위한탄소중립ㆍ녹색성장기본법"],"rationale":"정의조항의 타법 참조는 입안길잡이상 통상적·필요한 인용"},{"name":"세입세출·기금재원_열거_FP필터","logic":"조문제목에 '세입|세출|기금|재원|계정' OR 본문 '다음 각 호의 재원|세입은 다음 각 호와 같다' → FP","effect":"FP_FILTER","examples":["L-01-001@과학기술기본법","L-01-003@교통시설특별회계법","L-01-006@교통시설특별회계법","L-01-001@농어촌구조개선특별회계법"],"rationale":"회계조항은 근거법 명시가 필수, 입안기준상 정상"},{"name":"부담금·조세_감면근거법_열거_FP필터","logic":"본문 '감면할 수 있다' AND 「(개발이익|농지|초지|산지관리|대도시권광역교통|지방세특례)」≥3 → FP","effect":"FP_FILTER","examples":["L-01-002@국가첨단전략산업경쟁력강화및보호에관한특별조치법","L-01-001@국제회의산업육성에관한법률","L-01-003@농촌공간재구조화및재생지원에관한법률","L-01-003@대중교통의육성및이용촉진에관한법률","L-01-002@녹색건축물조성지원법"],"rationale":"부담금 감면조항은 개별법 인용이 구조상 불가피"},{"name":"다른계획과의관계_FP필터","logic":"조문제목 '다른 계획과의 관계|적용 범위|다른 법령과의 관계' AND 호열거에 '제X조에 따른' 반복 → FP","effect":"FP_FILTER","examples":["L-01-002@국가전략기술육성에관한특별법","L-01-002@국가통합교통체계효율화법","L-01-002@노후거점산업단지의활력증진및경쟁력강화를위한특별법","L-01-002@대구경북통합신공항건설을위한특별법","L-01-001@궤도운송법"],"rationale":"계획 간 조화·우선순위 조항은 인용이 본질"},{"name":"인허가의제·준용_FP필터","logic":"본문 '허가를 받은 것으로 본다|준용한다|공무원으로 본다' AND 「」≥5 → FP","effect":"FP_FILTER","examples":["L-01-001@과학관의설립ㆍ운영및육성에관한법률","L-01-001@기후변화대응기술개발촉진법","L-01-001@녹색융합클러스터의조성및육성에관한법률"],"rationale":"의제·준용 조항은 대상법 명시 의무"},{"name":"자격·범위열거_FP필터","logic":"본문 '다음 각 호의 어느 하나에 해당하는 자' AND 각 호가 '「법」에 따른 N' 패턴 ≥3 → FP","effect":"FP_FILTER","examples":["L-01-001@공항소음방지및소음대책지역지원에관한법률","L-01-001@과세자료의제출및관리에관한법률","L-01-002@농림수산식품투자조합결성및운용에관한법률","L-01-002@대중교통의육성및이용촉진에관한법률","L-01-002@기초연구진흥및기술개발지원에관한법률"],"rationale":"수범자·자격 범위 열거는 명확성 원칙상 필수"},{"name":"벌칙조_타법죄형_FP필터","logic":"조문제목 '벌칙' AND '해당 규정의 벌칙에 따른다' 패턴 → FP","effect":"FP_FILTER","examples":["L-01-003@국가자원안보특별법","L-01-001@군사법원법"],"rationale":"벌칙 경합조정은 타법 인용 불가피"},{"name":"실체조항_인용집중_TP부스트","logic":"조문제목이 정의/세입/감면/계획/적용범위 아님 AND 「」≥6 AND 한 항(項)에 ≥3개 집중 → TP_BOOST","effect":"TP_BOOST","examples":["L-01-001@관세법","L-01-005@낙동강수계물관리및주민지원등에관한법률","L-01-001@교원의지위향상및교육활동보호를위한특별법","L-01-003@대기환경보전법"],"rationale":"실체적 권리·의무 조항에 인용 과밀이면 독해 저해"}],"missed_patterns":[{"name":"매개법령_경유참조(이중인용)","logic":"「A법」 제X조에 따른 정의가 또 「B법」을 인용하는 연쇄 — '「A」제X조제Y호의 「B」 제Z조' 패턴","examples":["「국제조세조정에관한법률」 §52","「국세기본법」 §2"]},{"name":"호별_조건분기_타법별_상이처리","logic":"각 호가 업권/법률별로 서로 다른 효과·근거조를 지정 → 호 간 일관성 결여","examples":["「금융복합기업집단의감독에관한법률」 §23","「국가자원안보특별법」 §42"]},{"name":"개정연혁_과다누적","logic":"<개정 YYYY.M.D> 태그 ≥10회 → 누적개정으로 조문구조 파편화","examples":["「국세기본법」 §2","「기후위기대응을위한탄소중립ㆍ녹색성장기본법」 §2"]},{"name":"미래시행일_혼재","logic":"개정태그 중 시행일이 현재(2026-05-19) 이후 — 시행 전·후 규정 혼재로 적용혼란","examples":["「국세기본법」 §47의4(2025.12.23)","「교원의지위향상및교육활동보호를위한특별법」 §25(2026.2.19)"]}]}
