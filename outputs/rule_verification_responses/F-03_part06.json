  "new_signals": [
    {
      "name": "정의·목적·선언조 FP필터",
      "logic": "조문제목 ~ /(목적|정의|원칙|종류|시간|범위)$/ OR 본문 ~ /(란.*말한다|.*같다\\.$|초과할 수 없다)/ → F-03 매칭시 FP",
      "effect": "FP_FILTER",
      "examples": ["F-03-001@형법", "F-03-001@한국국제협력단법", "F-03-001@지역신문발전지원특별법", "F-03-004@형의집행및수용자의처우에관한법률", "F-03-001@출입국관리법"],
      "rationale": "정의·목적·범위 선언 조문은 처분권 부여가 아니므로 약한처분 패턴이 무의미"
    },
    {
