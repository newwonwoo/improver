  "new_signals": [
    {
      "name": "내부 지휘감독 FP 필터 (소속/지휘체계)",
      "logic": "본문에 '소속 (공무원|직원|군인|판사|검사)' OR '명을 받아' OR '지휘ㆍ감독' AND 객체가 동일 조직 소속이면 FP. 정규식: (소속\\s*(공무원|직원|군인|판사|검사|대원))|(명을\\s*받아.{0,30}지휘ㆍ감독)",
      "effect": "FP_FILTER",
      "examples": ["G-03-001@공익법무관에관한법률", "G-03-001@국립외교원법", "G-03-001@대한민국재외공관설치법", "G-03-003@법원조직법", "G-03-001@국회사무처법"],
      "rationale": "G-03은 외부 피감독자에 대한 행정감독 결함 탐지가 목적. 조직 내부 상관-부하 간 지휘감독은 정부조직법·국가공무원법 일반원리로 별도 절차 불요."
    },
    {
      "name": "복무감독 조문 FP 필터",
      "logic": "조문제목 또는 본문에 '복무\\s*(감독|관리)' AND 객체가 자연인 공무원/요원이면 FP",
      "effect": "FP_FILTER",
      "examples": ["G-03-001@공익법무관에관한법률", "G-03-001@공중방역수의사에관한법률", "G-03-001@농어촌등보건의료를위한특별조치법", "G-03-001@대체역의편입및복무등에관한법률"],
      "rationale": "복무감독은 인사복무관리로 국가공무원법·복무규정에 별도 통제장치 존재."
    },
    {
      "name": "법인·단체 외부감독 TP 부스트",
      "logic": "(주무관청|장관|위원회)가 (법인|협회|회|조합|기금|공단)을 '감독한다' AND 후속 항에 검사권·시정명령·공개 키워드 부재",
      "effect": "TP_BOOST",
      "examples": ["G-03-001@공동주택관리법", "G-03-003@국민체육진흥법", "G-03-002@담보부사채신탁법", "G-03-002@농업협동조합법", "G-03-001@민법"],
      "rationale": "외부 사인·단체에 대한 침익적 감독권은 감사원·법제처 기준상 범위·절차·불복 명시 의무."
    },
    {
      "name": "위임받은 자 지휘감독 FP",
      "logic": "직전 항 '위임 또는 위탁할 수 있다' AND 당해 항 '위임 또는 위탁을 받은 자를.{0,10}지휘ㆍ감독'",
      "effect": "FP_FILTER",
      "examples": ["G-03-001@대외무역법", "G-03-001@가족관계의등록등에관한법률"],
      "rationale": "행정권한위임위탁규정에 일반 지휘감독 절차 마련."
    },
    {
      "name": "감독수단 명시 조문 FP 다운그레이드",
      "logic": "조문 또는 동조 후속항에 (교체요구|시정요구|시정명령|보고요구|검사) AND 불응시 처분 절차 존재",
      "effect": "FP_FILTER",
      "examples": ["G-03-001@공직선거법", "G-03-001@공증인법"],
      "rationale": "감독 5요소 중 상당수 충족."
    },
    {
      "name": "기본법·민사법 결함 BORDER",
      "logic": "법률 카테고리 in {민사법, 형사법, 기본법} AND 짧은 선언적 조문(50자 미만)",
      "effect": "FP_FILTER",
      "examples": ["G-03-001@민법", "G-03-002@민법", "G-03-001@교육기본법"],
      "rationale": "기본법·민사법은 세부 절차를 시행령·특별법에 위임하는 입법체계."
    }
  ],
