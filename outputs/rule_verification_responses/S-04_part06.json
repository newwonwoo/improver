{"bundle_id":"S-04_part06","rule_id":"S-04","verdicts":[{"fid":"S-04-005@정신건강증진및정신질환자복지서비스지원에관한법률","v":"FP","ev":"과태료 각호 위반행위 열거"},{"fid":"S-04-002@제품안전기본법","v":"BORDER","ev":"관리원 업무 12호+위탁 잔여"},{"fid":"S-04-001@조경진흥법","v":"TP","ev":"기본계획 11호+'필요한 사항'"},{"fid":"S-04-002@주민등록법","v":"FP","ev":"벌칙 구성요건 열거"},{"fid":"S-04-001@주세법","v":"FP","ev":"정의조항 용어열거"},{"fid":"S-04-002@주차장법","v":"FP","ev":"벌칙 12호 구성요건"},{"fid":"S-04-001@중소기업은행법","v":"BORDER","ev":"정관 필수기재사항 11호"},{"fid":"S-04-002@중소기업창업지원법","v":"TP","ev":"종합계획 10호+'필요사항'"},{"fid":"S-04-001@지방자치단체보조금관리에관한법률","v":"BORDER","ev":"연계 정보시스템 10호+위임"},{"fid":"S-04-003@지방자치분권및지역균형발전에관한특별법","v":"TP","ev":"심의 14호+'위원장 부의'"},{"fid":"S-04-001@지방회계법","v":"BORDER","ev":"결산첨부 12호+대통령령"},{"fid":"S-04-001@지하안전관리에관한특별법","v":"FP","ev":"정의조항 13개 용어"},{"fid":"S-04-001@진로교육법","v":"TP","ev":"센터 업무 10호+위임"},{"fid":"S-04-001@참전유공자예우및단체설립에관한법률","v":"BORDER","ev":"정관 13호 형식적"},{"fid":"S-04-004@채무자회생및파산에관한법률","v":"FP","ev":"합병 회생계획 기재"},{"fid":"S-04-011@채무자회생및파산에관한법률","v":"FP","ev":"재단채권 범위 한정"},{"fid":"S-04-003@철도의건설및철도시설유지관리에관한법률","v":"FP","ev":"등록취소 사유 14호"},{"fid":"S-04-003@첨단재생의료및첨단바이오의약품안전및지원에관한법률","v":"FP","ev":"허가취소 사유 열거"},{"fid":"S-04-001@청소년보호법","v":"FP","ev":"매체별 표시의무자 구분"},{"fid":"S-04-003@청소년활동진흥법","v":"FP","ev":"과태료 구성요건 12호"},{"fid":"S-04-004@초고층및지하연계복합건축물재난관리에관한특별법","v":"TP","ev":"총괄재난관리자 10호+위임"},{"fid":"S-04-002@총포ㆍ도검ㆍ화약류등의안전관리에관한법률","v":"TP","ev":"협회 사업 10호+포괄"},{"fid":"S-04-002@치매관리법","v":"TP","ev":"센터 업무 10호+포괄위임"},{"fid":"S-04-003@친환경농어업육성및유기식품등의관리ㆍ지원에관한법률","v":"FP","ev":"공시기관 취소사유"},{"fid":"S-04-002@토양환경보전법","v":"FP","ev":"과태료 13호 구성요건"},{"fid":"S-04-002@평생교육법","v":"BORDER","ev":"공시정보 11호+포괄"},{"fid":"S-04-005@폐기물관리법","v":"FP","ev":"과태료 호번 구성요건"},{"fid":"S-04-005@하수도법","v":"FP","ev":"허가취소 13호 사유"},{"fid":"S-04-001@학원의설립ㆍ운영및과외교습에관한법률","v":"FP","ev":"행정처분 사유 12호"},{"fid":"S-04-002@한강수계상수원수질개선및주민지원등에관한법률","v":"TP","ev":"기금 용도 10호+위임"},{"fid":"S-04-001@한국산업인력공단법","v":"BORDER","ev":"정관 필수기재 11호"},{"fid":"S-04-002@한국자산관리공사설립등에관한법률","v":"FP","ev":"삭제호 다수 10호"},{"fid":"S-04-002@한국투자공사법","v":"BORDER","ev":"운영위 심의 10호+정관"},{"fid":"S-04-002@한국해양진흥공사법","v":"TP","ev":"공사 업무 13호+포괄위임"},{"fid":"S-04-001@한국환경산업기술원법","v":"BORDER","ev":"정관 10호+'대통령령'"},{"fid":"S-04-001@한의약육성법","v":"BORDER","ev":"정관 11호 형식"},{"fid":"S-04-004@할부거래에관한법률","v":"FP","ev":"본문 짧음 매칭오류"},{"fid":"S-04-010@항공안전법","v":"FP","ev":"부과·징수 절차조항"},{"fid":"S-04-002@항로표지법","v":"BORDER","ev":"정관 12호 형식"},{"fid":"S-04-003@항로표지법","v":"FP","ev":"과태료 13호 구성요건"},{"fid":"S-04-001@해상풍력보급촉진및산업육성에관한특별법","v":"TP","ev":"위원회 심의 11호+포괄"},{"fid":"S-04-001@혈액관리법","v":"FP","ev":"정의조항 11개 용어"},{"fid":"S-04-001@형사사법절차에서의전자문서이용등에관한법률","v":"FP","ev":"적용대상 법률 열거"},{"fid":"S-04-003@화물자동차운수사업법","v":"FP","ev":"자격취소 사유 10호"},{"fid":"S-04-004@화장품법","v":"FP","ev":"등록취소 사유 14호"},{"fid":"S-04-001@화학물질관리법","v":"FP","ev":"정의조항 13개 용어"},{"fid":"S-04-003@화학물질관리법","v":"TP","ev":"계획서 11호+포괄"},{"fid":"S-04-001@환경분야시험ㆍ검사등에관한법률","v":"FP","ev":"공정시험 대상분야 12개"},{"fid":"S-04-001@환경친화적자동차의개발및보급촉진에관한법률","v":"FP","ev":"정의조항 용어 10개"},{"fid":"S-04-001@후견등기에관한법률","v":"BORDER","ev":"청구권자 11호+대법규칙"}],"new_signals":[{"name":"정의조문 열거 FP필터","logic":"조제목 in ['정의','용어의 정의'] OR 본문 시작 '이 법에서 사용하는 용어의 뜻은' → S-04 강제 FP","effect":"FP_FILTER","examples":["S-04-001@주세법","S-04-001@지하안전관리에관한특별법","S-04-001@혈액관리법","S-04-001@화학물질관리법","S-04-001@환경친화적자동차의개발및보급촉진에관한법률"],"rationale":"정의조항은 본질상 용어 다수 나열이 정상이며 결함이 아님(법제처 입안길잡이)."},{"name":"벌칙·과태료 구성요건 FP필터","logic":"조제목 in ['벌칙','과태료'] AND 호 본문에 '위반하여|거부ㆍ방해|거짓' 출현률>50% → S-04 FP","effect":"FP_FILTER","examples":["S-04-005@정신건강증진및정신질환자복지서비스지원에관한법률","S-04-002@주민등록법","S-04-002@주차장법","S-04-005@폐기물관리법","S-04-002@토양환경보전법","S-04-003@항로표지법"],"rationale":"벌칙·과태료는 죄형법정주의·명확성 원칙상 구성요건 빠짐없는 열거가 필수."},{"name":"인허가 취소사유 FP필터","logic":"조제목에 '취소|행정처분|등록취소|허가취소|자격취소' AND 단서에 '제○호는 취소하여야' → FP","effect":"FP_FILTER","examples":["S-04-003@철도의건설및철도시설유지관리에관한법률","S-04-003@친환경농어업육성및유기식품등의관리ㆍ지원에관한법률","S-04-005@하수도법","S-04-001@학원의설립ㆍ운영및과외교습에관한법률","S-04-004@화장품법"],"rationale":"행정처분 사유 한정열거는 처분의 예측가능성 확보 차원에서 정당(감사원 내부통제)."},{"name":"계획·기금 포괄위임 TP부스트","logic":"조제목에 '계획|기금|업무' AND 마지막호 '그 밖에 ~ 대통령령으로 정하는' AND 호≥10 → S-04 TP_BOOST","effect":"TP_BOOST","examples":["S-04-001@조경진흥법","S-04-002@중소기업창업지원법","S-04-003@지방자치분권및지역균형발전에관한특별법","S-04-002@한강수계상수원수질개선및주민지원등에관한법률","S-04-002@한국해양진흥공사법"],"rationale":"기본계획·기금용도에 포괄적 위임호가 있으면 법률유보·명확성 원칙 위배 우려(권익위 규제개혁)."},{"name":"정관 필수기재사항 BORDER","logic":"조제목='정관' AND 1호='목적', 2호='명칭' 형식 매칭 → BORDER (개별법 표준양식)","effect":"FP_FILTER","examples":["S-04-001@중소기업은행법","S-04-001@참전유공자예우및단체설립에관한법률","S-04-001@한국산업인력공단법","S-04-001@한국환경산업기술원법","S-04-001@한의약육성법"],"rationale":"공공기관·법인 정관 필수기재사항은 민법·상법 표준양식 답습으로 결함성 약함."},{"name":"단순 인용·절차조항 매칭오류 FP","logic":"본문 길이<150자 AND 호 패턴 미검출 → S-04 자동 FP (룰엔진 오매칭)","effect":"FP_FILTER","examples":["S-04-004@할부거래에관한법률","S-04-010@항공안전법"],"rationale":"본문이 짧은 단순 절차문(부과·징수)에서 호 카운트가 오작동."},{"name":"삭제호 다수 FP","logic":"호 중 '삭제 <YYYY.M.D>' 비율>30% → S-04 FP (실질 호 적음)","effect":"FP_FILTER","examples":["S-04-002@한국자산관리공사설립등에관한법률"],"rationale":"삭제된 호 제외시 실질 열거 수 적어 열거과다 아님."}],"missed_patterns":[{"name":"동일 조 내 중복 항(②③) 같은 호 구조 반복","logic":"한 조 내 항이 다수이고 각 항이 동일한 호 구조(11~14호) 반복 → 통합 가능 결함","examples":["「평생교육법」 §34의2","「폐기물관리법」 §68","「토양환경보전법」 §32"]},{"name":"호번호 '◯의◯' 남발 (체계정합성)","logic":"'N의M' 형식 호번호≥3개 + 본조 호≥10 → 누더기 개정 흔적, 체계 재정비 권고","examples":["「폐기물관리법」 §68①","「화장품법」 §24①","「학원의설립ㆍ운영및과외교습에관한법률」 §17①"]},{"name":"다른 법 인용 열거형 (참조 과다)","logic":"호 중 「○○법」 인용 비율>70% → 별표 이관 권고","examples":["「형사사법절차에서의전자문서이용등에관한법률」 §3","「지방자치단체보조금관리에관한법률」 §28③","「환경분야시험ㆍ검사등에관한법률」 §6①"]},{"name":"동일 어두 반복 호 (별표 이관)","logic":"호 어두에 동일 단어(예: '총포ㆍ화약류ㆍ분사기…') 반복률>60% → 별표/표준양식 이관","examples":["「총포ㆍ도검ㆍ화약류등의안전관리에관한법률」 §52","「청소년보호법」 §13①"]}]}
