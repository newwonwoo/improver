{"bundle_id":"L-01_part05","rule_id":"L-01","verdicts":[{"fid":"L-01-001@소음ㆍ진동관리법","v":"FP","ev":"제2조 정의조항 — 타법 용어 인용"},{"fid":"L-01-002@수산업협동조합법","v":"FP","ev":"제51조 결격사유 — 죄목·금융기관 인용"},{"fid":"L-01-002@수산자원관리법","v":"FP","ev":"공단 사업범위 타법 인용"},{"fid":"L-01-001@수소경제육성및수소안전관리에관한법률","v":"BORDER","ev":"제17조 부담금 면제 — 4개 부담금"},{"fid":"L-01-001@신용협동조합법","v":"FP","ev":"제6조 다른 법률과의 관계"},{"fid":"L-01-003@신행정수도후속대책을위한연기ㆍ공주지역행정중심복합도시건설을위한특별법","v":"BORDER","ev":"제52조 6개 부담금 감면 병렬"},{"fid":"L-01-008@아동복지법","v":"FP","ev":"제44조 위탁대상 금융기관 열거"},{"fid":"L-01-001@악취방지법","v":"FP","ev":"제9조 권리의무 승계 절차법 인용"},{"fid":"L-01-002@야생생물보호및관리에관한법률","v":"BORDER","ev":"제21조 허가·예외 규정 다수 인용"},{"fid":"L-01-005@양식산업발전법","v":"TP","ev":"제43조 의제조항 5개 법률 의제"},{"fid":"L-01-001@어장관리법","v":"FP","ev":"제19조 승계 절차법 인용"},{"fid":"L-01-002@어촌ㆍ어항법","v":"FP","ev":"제33조 협의 — 타법 권리설정 인용"},{"fid":"L-01-001@연안관리법","v":"FP","ev":"제2조 정의 — 지역경계 타법 인용"},{"fid":"L-01-001@연안사고예방에관한법률","v":"BORDER","ev":"제12조 9개 법률 적용제외"},{"fid":"L-01-005@영산강ㆍ섬진강수계물관리및주민지원등에관한법률","v":"FP","ev":"자료요청 6개 법률 자료종류"},{"fid":"L-01-001@옥외광고물등관리법","v":"BORDER","ev":"제3조 허가대상 지역 타법 인용"},{"fid":"L-01-002@원자력안전법","v":"FP","ev":"기금재원 타법 인용"},{"fid":"L-01-001@유전자원의접근ㆍ이용및이익공유에관한법률","v":"FP","ev":"부처 소관분야 타법 명시"},{"fid":"L-01-001@윤석열전대통령등에의한내란ㆍ외환행위의진상규명을위한특별검사임명등에관한법률","v":"FP","ev":"준용 절차법 인용"},{"fid":"L-01-001@의료ㆍ요양등지역돌봄의통합지원에관한법률","v":"BORDER","ev":"제22조 정보시스템 8개 법률 연계"},{"fid":"L-01-004@의료법","v":"BORDER","ev":"제57조 광고매체·심의단체 인용"},{"fid":"L-01-001@의료사고피해구제및의료분쟁조정등에관한법률","v":"FP","ev":"제2조 정의 — 보건의료인 인용"},{"fid":"L-01-002@인구감소지역지원특별법","v":"BORDER","ev":"제22조 교육기반 7개 법률"},{"fid":"L-01-001@인구감소지역지원특별법","v":"TP","ev":"제4조 다른 법률 우선 — 7개 계획"},{"fid":"L-01-002@임업ㆍ산림공익기능증진을위한직접지불제도운영에관한법률","v":"BORDER","ev":"제7조 지급제외 산지 인용"},{"fid":"L-01-002@자연환경보전법","v":"FP","ev":"부담금 부과대상 타법사업 인용"},{"fid":"L-01-003@자유무역지역의지정및운영에관한법률","v":"FP","ev":"지식재산권 9개 권리법 병렬"},{"fid":"L-01-002@자율운항선박개발및상용화촉진에관한법률","v":"BORDER","ev":"제12조 7개 법률 연계항목"},{"fid":"L-01-001@자율운항선박개발및상용화촉진에관한법률","v":"FP","ev":"제2조 정의 타법 인용"},{"fid":"L-01-003@장애아동복지지원법","v":"FP","ev":"결격사유 죄목·자격 인용"},{"fid":"L-01-002@장애인복지법","v":"FP","ev":"평가반영 — 4개 평가법 인용"},{"fid":"L-01-001@재난및안전관리기본법","v":"FP","ev":"단일조문 짧음 — 인용중복"},{"fid":"L-01-002@재해위험개선사업및이주대책에관한특별법","v":"TP","ev":"제22조 특례 — 7개 법률 우선"},{"fid":"L-01-003@전기안전관리법","v":"FP","ev":"벌칙조 짧음 — 인용 미발견"},{"fid":"L-01-006@전세사기피해자지원및주거안정에관한특별법","v":"BORDER","ev":"자료요청 절차법·금융법 인용"},{"fid":"L-01-001@전통사찰의보존및지원에관한법률","v":"TP","ev":"제9조의2 의제 7개 허가"},{"fid":"L-01-002@전파법","v":"BORDER","ev":"전파차단 8개 법률 활동근거"},{"fid":"L-01-001@접경지역지원특별법","v":"BORDER","ev":"발전계획 6개 상위계획"},{"fid":"L-01-001@정보통신산업진흥법","v":"FP","ev":"제2조 정의 산업범위 타법"},{"fid":"L-01-005@제주특별자치도설치및국제자유도시조성을위한특별법","v":"FP","ev":"제362조 매수청구 절차법 인용"},{"fid":"L-01-006@제주특별자치도설치및국제자유도시조성을위한특별법","v":"FP","ev":"제364조 환경영향평가법 반복인용"},{"fid":"L-01-030@조세특례제한법","v":"TP","ev":"제121조의17 감면대상 8개 법률"},{"fid":"L-01-010@조세특례제한법","v":"BORDER","ev":"제63조 감면 — 지역구분 인용"},{"fid":"L-01-015@조세특례제한법","v":"FP","ev":"제88조의4 우리사주 — 근로복지법 반복"},{"fid":"L-01-001@주민등록법","v":"TP","ev":"제17조 전입신고 6개 법률 의제"},{"fid":"L-01-001@주식ㆍ사채등의전자등록에관한법률","v":"FP","ev":"제2조 단기사채 요건 — 법률중복"},{"fid":"L-01-003@주택법","v":"TP","ev":"제18조 통합심의 8개 법률 사항"},{"fid":"L-01-001@중소기업스마트제조혁신촉진에관한법률","v":"FP","ev":"산학협력 기관 5개 법률 인용"},{"fid":"L-01-001@중소기업인력지원특별법","v":"FP","ev":"제15조 겸임 — 기관 근거법 인용"},{"fid":"L-01-002@중소기업인력지원특별법","v":"FP","ev":"제15조의2 휴직 — 4개 공무원법"}],"new_signals":[{"name":"정의조항_타법용어인용_FP","logic":"조문제목 == '정의' AND 본문에 '~란 「.*법」.*에 따른.*을 말한다' 패턴 ≥3회","effect":"FP_FILTER","examples":["L-01-001@소음ㆍ진동관리법","L-01-001@연안관리법","L-01-001@정보통신산업진흥법","L-01-001@의료사고피해구제및의료분쟁조정등에관한법률","L-01-001@자율운항선박개발및상용화촉진에관한법률"],"rationale":"용어정의조에서 타법 용어를 인용하는 것은 표준 입법기술이며 독해곤란 결함 아님."},{"name":"결격사유_죄목인용_FP","logic":"조문제목 contains '결격사유' AND 본문에 '「.*법」 제.*조.*에 규정된 죄' OR '벌금형' 패턴","effect":"FP_FILTER","examples":["L-01-002@수산업협동조합법","L-01-003@장애아동복지지원법"],"rationale":"결격사유에서 범죄 근거조문 명시는 죄형법정주의상 필수이며 다수 인용은 정상."},{"name":"승계조_절차법인용_FP","logic":"조문제목 contains ('승계'|'권리.*의무') AND 인용법률 set ⊇ {민사집행법, 채무자회생법, 국세징수법}","effect":"FP_FILTER","examples":["L-01-001@악취방지법","L-01-001@어장관리법"],"rationale":"경매·환가·압류 등 절차 승계는 표준 인용 패턴이며 결함 아님."},{"name":"의제조항_TP_BOOST","logic":"본문에 '받은 것으로 본다' OR '의제' AND 인용법률 ≥5개 (한 항 내)","effect":"TP_BOOST","examples":["L-01-005@양식산업발전법","L-01-001@전통사찰의보존및지원에관한법률","L-01-003@주택법"],"rationale":"의제조항은 다수 허가 의제로 권리관계 혼란 위험이 크고 통합심의·규제완화 측면에서 실질 독해곤란."},{"name":"다른법률관계조_특례병렬_TP_BOOST","logic":"조문제목 contains ('다른 법률과의 관계'|'특례') AND '우선하여 적용' AND 호 ≥5개 타법 특례","effect":"TP_BOOST","examples":["L-01-001@인구감소지역지원특별법","L-01-002@재해위험개선사업및이주대책에관한특별법"],"rationale":"법률 적용 우선순위·특례 다수 병렬은 수범자에게 적용법령 식별 어려움 야기."},{"name":"준용조_FP","logic":"본문에 '준용한다' AND 인용법률이 절차/형사 분야 다수","effect":"FP_FILTER","examples":["L-01-001@윤석열전대통령등에의한내란ㆍ외환행위의진상규명을위한특별검사임명등에관한법률"],"rationale":"준용 인용은 입법경제상 필수이며 독해곤란 결함 아님."}],"missed_patterns":[{"name":"의제효과_누락허가_미명시","logic":"의제조 인용법률 N개 vs 시행령·시행규칙에 절차 규정이 누락된 항목 식별","examples":["「전통사찰의보존및지원에관한법률」 §9의2","「양식산업발전법」 §43"]},{"name":"부담금감면_법적근거_분산","logic":"한 조문에 부담금 ≥4종 감면 + 각 부담금 산정·반환 절차 산재","examples":["「수소경제육성및수소안전관리에관한법률」 §17","「신행정수도후속대책특별법」 §52"]},{"name":"통합심의_위원회구성_복잡성","logic":"통합심의 대상사항 N개 ↔ 위원회 추천 위원 구성요건 산만","examples":["「주택법」 §18"]}]}