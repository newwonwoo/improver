"new_signals":[
{"name":"기념일/주간 지정 조문은 S-01 구조신호 무력화","logic":"제목 또는 본문에 /(\\S+)의 ?날|기념일|주간/ 매칭 AND 제재·처분 키워드 부재 -> FP_FILTER","effect":"FP_FILTER","examples":["S-01-001@모자보건법","S-01-001@의료기기법","S-01-001@임업및산촌진흥촉진에관한법률"],"rationale":"기념일 지정은 정책선언 조문으로 삽입조 비율은 입법연혁 부산물일 뿐 결함 아님."},
{"name":"정의·적용·관계 조문 FP 필터","logic":"제목 in {정의,적용범위,다른 법률과의 관계,기본이념,사명,책무} OR 본문에 /\"[^\"]+\"(란|라 함은).*말한다/ -> FP_FILTER","effect":"FP_FILTER","examples":["S-01-001@노인복지법","S-01-001@예술인복지법","S-01-001@관세사법","S-01-001@가정폭력방지및피해자보호등에관한법률"],"rationale":"용어정의·선언 조문에서 잡힌 삽입조 비율은 의미 결함이 아니라 구조적 산물."},
{"name":"계획수립 조문 FP 필터","logic":"제목에 /기본계획|시행계획|투자전략|종합계획|관리계획/ AND 본문에 /수립ㆍ시행하여야|5년마다|심의를 거쳐/ -> FP_FILTER","effect":"FP_FILTER","examples":["S-01-001@고압가스안전관리법","S-01-001@과학기술기본법","S-01-001@유아교육법","S-01-001@우주개발진흥법"],"rationale":"계획수립 조문은 절차·정책의무 성격으로 제재공백 자체가 결함 아님."},
{"name":"위원회·기관 설치/구성 조문 FP 필터","logic":"제목 또는 본문에 /위원회|협의회|보장원|부설기관|센터/ AND /둔다|설치|구성ㆍ운영|정관으로 정하는/ AND 처분 키워드 부재 -> FP_FILTER","effect":"FP_FILTER","examples":["S-01-001@대ㆍ중소기업상생협력촉진에관한법률","S-01-001@혈액관리법","S-01-001@시체해부및보존에관한법률","S-01-001@대구경북과학기술원법"],"rationale":"조직 설치·구성 위임은 수익적/내부조직 규정으로 침익성 없음."},
{"name":"삭제 조문 즉시 FP","logic":"본문이 /^제\\S+조의\\d+삭제 ?<\\d{4}/ 만으로 구성 -> FP_FILTER","effect":"FP_FILTER","examples":["S-01-001@자원의절약과재활용촉진에관한법률","S-01-001@참전유공자예우및단체설립에관한법률","S-01-001@화물자동차운수사업법"],"rationale":"삭제된 조문은 실질 내용이 없어 S-01 매칭이 무의미."},
{"name":"고비율(>=55%) + 실체 의무조문 BORDER 격상","logic":"삽입조비율 >= 0.55 AND 제목/본문이 정의·기념일·삭제·선언 아님 AND (절차/요건/처분 내용 존재) -> BORDER","effect":"TP_BOOST","examples":["S-01-001@대도시권광역교통관리에관한특별법","S-01-001@벤처기업육성에관한특별법","S-01-001@대부업등의등록및금융이용자보호에관한법률"],"rationale":"비율 55% 이상이면 입법체계 정비 필요성이 실재할 수 있어 보류·검토 대상."}
],
"missed_patterns":[
{"name":"벌칙 본문이 인용 조항으로만 구성된 위임형 벌칙","logic":"제목 부재 + 본문이 /제\\S+조의\\d+제\\d+항.*위반.*징역|벌금/ 단일문장 -> 별도 벌칙명확성 룰","examples":["「수목원ㆍ정원의조성및진흥에관한법률」 §6의2"]},
{"name":"기념일 조문에 시행령 위임만 있고 행사 근거 모호","logic":"기념일 지정 AND /행사.*지원할 수 있다/ AND 구체기준 부재 -> 재량남용 점검","examples":["「의료기기법」 §2의2","「모자보건법」 §3의2"]},
{"name":"협조요청 '특별한 사유 없으면 따라야 한다' 준의무화","logic":"/협력|자료의 제출/.*요청할 수 있다.*특별한 사유가 없으면.*따라야 -> 사실상 의무부과 명확성 점검","examples":["「고압가스안전관리법」 §3의2④","「대ㆍ중소기업상생협력촉진에관한법률」 §20의2④"]}
]
}
