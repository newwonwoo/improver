  "new_signals": [
    {
      "name": "위원회_심의사항_열거_FP",
      "logic": "조문제목 =~ /(위원회|심의위원회|평의원회|추모위원회)/ AND 본문 =~ /다음 각 호의 사항을 (심의|자문|의결)/ AND 마지막호 =~ /그 밖에.*인정하는 사항/",
      "effect": "FP_FILTER",
      "examples": ["E-01-001@한국에너지공과대학교법", "E-01-005@12ㆍ29여객기참사피해구제및지원등을위한특별법", "E-01-016@건강기능식품에관한법률", "E-01-003@무형유산의보전및진흥에관한법률", "E-01-001@군사정전에관한협정체결이후납북피해자의보상및지원에관한법률"],
      "rationale": "위원회 심의사항 열거는 입법기술상 정형구조로, 단순 호수만으로 조건중첩 결함으로 보기 어려움(법제처 입안길잡이)"
    },
    {
      "name": "정의조문_용어열거_FP",
      "logic": "조문제목 == '정의' OR 본문 =~ /이 법에서 사용하는 용어의 뜻은 다음과 같다/ OR /\"[가-힣]+\"(이)?란.*말한다/",
      "effect": "FP_FILTER",
      "examples": ["E-01-001@화재의예방및안전관리에관한법률", "E-01-001@국가공무원법", "E-01-001@금융실명거래및비밀보장에관한법률", "E-01-001@데이터산업진흥및이용촉진에관한기본법"],
      "rationale": "정의 조문의 다항 열거는 본질상 조건중첩이 아니라 용어 정의의 누적이므로 결함이 아님"
    },
    {
      "name": "벌칙조문_조건중첩_FP",
      "logic": "조문제목 =~ /^(벌칙|과태료)$/ OR 본문 =~ /(\\d+년 이하의 징역|\\d+(천|백)만원 이하의 벌금|\\d+(천|백)만원 이하의 과태료)/",
      "effect": "FP_FILTER",
      "examples": ["E-01-007@기상법", "E-01-035@농지법"],
      "rationale": "벌칙 조문의 각호 열거는 권리제한이지 조건중첩 결함이 아님(권익위 규제개혁 기준)"
    },
    {
      "name": "이행강제금_지정취소_단서_TP_BOOST",
      "logic": "조문제목 =~ /(이행강제금|지정 ?취소|허가 ?취소)/ AND 본문 =~ /다음 각 호의 어느 하나/ AND 단서 =~ /다만.*취소하여야 한다|다만.*그러하지 아니하다/ AND 절수 ≥4",
      "effect": "TP_BOOST",
      "examples": ["E-01-029@공유수면관리및매립에관한법률", "E-01-034@농수산물품질관리법", "E-01-051@대기환경보전법", "E-01-070@국세기본법"],
      "rationale": "처분조문의 단서·강행·재량이 혼합된 다단조건은 명확성 원칙 위반 가능성으로 감사원·법제처 기준상 결함"
    },
    {
      "name": "수익적_지원조문_FP",
      "logic": "본문 =~ /(지원할 수 있다|제공할 수 있다|보조할 수 있다|면제한다|감면)/ AND 침익적_키워드_부재(처분|취소|제재|벌|강제)",
      "effect": "FP_FILTER",
      "examples": ["E-01-003@해외건설촉진법", "E-01-049@공공주택특별법", "E-01-015@국민연금법", "E-01-011@디지털포용법", "E-01-014@보훈보상대상자지원에관한법률"],
      "rationale": "수익적 재량(지원·면제·보조)은 침익적 처분이 아니므로 조건중첩 결함으로 보지 않음(공정위·권익위 기준)"
    },
    {
      "name": "정책의무_노력조문_FP",
      "logic": "본문 =~ /(노력하여야 한다|진흥|촉진|육성)/ AND 본문 =~ /(예산의 범위에서|예산의 범위 안에서)/",
      "effect": "FP_FILTER",
      "examples": ["E-01-001@과학기술분야정부출연연구기관등의설립ㆍ운영및육성에관한법률"],
