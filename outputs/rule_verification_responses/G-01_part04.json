{"bundle_id":"G-01_part04","rule_id":"G-01","verdicts":[{"fid":"G-01-010@도시및주거환경정비법","v":"FP","ev":"각호 단서 1개+산림 단서"},{"fid":"G-01-015@도시및주거환경정비법","v":"TP","ev":"③⑥⑧항 단서 다중중첩"},{"fid":"G-01-001@도시재정비촉진을위한특별법","v":"TP","ev":"①②항 모두 허가단서"},{"fid":"G-01-012@독점규제및공정거래에관한법률","v":"FP","ev":"③⑤항 송달동의 단서"},{"fid":"G-01-002@먹는물관리법","v":"TP","ev":"⑧항 단서+5호 단서 중첩"},{"fid":"G-01-001@물품관리법","v":"TP","ev":"①②항 동일 위임단서"},{"fid":"G-01-003@민간임대주택에관한특별법","v":"FP","ev":"단편조문 본문부족"},{"fid":"G-01-004@민사집행법","v":"TP","ev":"①④항 인도명령 단서중첩"},{"fid":"G-01-001@민사집행법","v":"FP","ev":"⑥⑦항 절차법 단서"},{"fid":"G-01-001@발명진흥법","v":"TP","ev":"①②항 권리귀속 단서중첩"},{"fid":"G-01-014@법인세법","v":"FP","ev":"세법 산정·준용 단서"},{"fid":"G-01-001@법학전문대학원설치ㆍ운영에관한법률","v":"TP","ev":"①②항 위임+필수취소"},{"fid":"G-01-001@변호사법","v":"TP","ev":"①⑦항 단서 자격제한"},{"fid":"G-01-004@변호사법","v":"FP","ev":"기간연장 단서(수익적)"},{"fid":"G-01-002@보험업법","v":"BORDER","ev":"①③항 인가단서·경미"},{"fid":"G-01-004@보험업법","v":"FP","ev":"민사법 사원관계 단서"},{"fid":"G-01-001@보호관찰등에관한법률","v":"TP","ev":"①②항 보호장구 고지단서"},{"fid":"G-01-002@보훈보상대상자지원에관한법률","v":"FP","ev":"④⑤항 통지면제(수익적)"},{"fid":"G-01-005@보훈보상대상자지원에관한법률","v":"FP","ev":"②③항 가점 제외단서"},{"fid":"G-01-001@복권및복권기금법","v":"FP","ev":"단편조문 본문부족"},{"fid":"G-01-006@부가가치세법","v":"FP","ev":"세법 대손공제 단서"},{"fid":"G-01-005@부동산등기법","v":"BORDER","ev":"①②항 정보제공 단서"},{"fid":"G-01-002@부정경쟁방지및영업비밀보호에관한법률","v":"FP","ev":"①②항 허락예외(수익적)"},{"fid":"G-01-003@부정경쟁방지및영업비밀보호에관한법률","v":"TP","ev":"③④항 취소·인계 단서"},{"fid":"G-01-002@부패방지및국민권익위원회의설치와운영에관한법률","v":"FP","ev":"②④항 절차편의 단서"},{"fid":"G-01-001@사립학교법","v":"FP","ev":"①④항 정원·구성 단서"},{"fid":"G-01-001@산림문화ㆍ휴양에관한법률","v":"TP","ev":"④항 필수취소+5⑥재지정"},{"fid":"G-01-002@산림문화ㆍ휴양에관한법률","v":"TP","ev":"①③항 지정·해제 단서"},{"fid":"G-01-002@산림자원의조성및관리에관한법률","v":"FP","ev":"①②호 개인정보 단서"},{"fid":"G-01-006@산업입지및개발에관한법률","v":"FP","ev":"준용조 면적·시행자 단서"},{"fid":"G-01-006@산업집적활성화및공장설립에관한법률","v":"FP","ev":"②③항 양도신고 단서"},{"fid":"G-01-005@산지관리법","v":"TP","ev":"①②항 환급 단서중첩"},{"fid":"G-01-008@산지관리법","v":"TP","ev":"①②항 동의·매매 단서"},{"fid":"G-01-012@산지관리법","v":"FP","ev":"②항 중간복구(수익적)"},{"fid":"G-01-002@상법","v":"FP","ev":"③④항 공고방법 단서"},{"fid":"G-01-012@상법","v":"FP","ev":"민사 운송책임 면책단서"},{"fid":"G-01-006@상속세및증여세법","v":"FP","ev":"세법 한도 단서"},{"fid":"G-01-008@상속세및증여세법","v":"FP","ev":"세법 환급 단서"},{"fid":"G-01-001@상업등기법","v":"FP","ev":"신청방법 절차 단서"},{"fid":"G-01-003@상업등기법","v":"FP","ev":"공탁금 회수 단서"},{"fid":"G-01-008@상표법","v":"FP","ev":"①②항 부정경쟁 단서"},{"fid":"G-01-003@새마을금고법","v":"TP","ev":"임원결격 다단단서"},{"fid":"G-01-001@새만금사업추진및지원에관한특별법","v":"FP","ev":"세입 농식품수익 단서"},{"fid":"G-01-001@생활물류서비스산업발전법","v":"TP","ev":"필수취소+임원교체 단서"},{"fid":"G-01-006@선원법","v":"FP","ev":"①②항 임금지급 단서"},{"fid":"G-01-002@성폭력방지및피해자보호등에관한법률","v":"FP","ev":"①4호 자립지원 단서"},{"fid":"G-01-003@성폭력범죄의처벌등에관한특례법","v":"FP","ev":"②⑥항 변호사 절차"},{"fid":"G-01-002@세무사법","v":"FP","ev":"①③항 변호사 직무"},{"fid":"G-01-001@세월호선체조사위원회의설치및운영에관한특별법","v":"FP","ev":"②⑤항 위원구성 단서"},{"fid":"G-01-001@세종특별자치시설치등에관한특별법","v":"FP","ev":"④⑤항 임명·임기 단서"}],"new_signals":[{"name":"수익적 단서 FP_FILTER","logic":"단서 본문 =~ /허락|동의|면제|환급|되돌려|감면|연장|갈음|아니할 수 있다/ AND 침익키워드(취소|정지|벌금|과징금) 부재 → FP","effect":"FP_FILTER","examples":["G-01-002@보훈보상대상자지원에관한법률","G-01-004@변호사법","G-01-002@부정경쟁방지및영업비밀보호에관한법률","G-01-012@산지관리법"],"rationale":"수범자에게 유리한 예외(수익적 재량)는 침익성 없어 결함 아님 — 권익위 규제개혁 기준."},{"name":"세법·민사법 면책단서 FP","logic":"법령명 =~ /세법|법인세|부가가치세|상속세|소득세|상법|민법|민사/ AND 단서 =~ /제외|준용|면제|적용하지 아니/ → FP","effect":"FP_FILTER","examples":["G-01-014@법인세법","G-01-006@부가가치세법","G-01-006@상속세및증여세법","G-01-002@상법","G-01-012@상법"],"rationale":"조세·민사 면책단서는 과세·책임의 합리적 구체화이며 행정처분 결함 아님."},{"name":"단편조문(인용·단독항) FP","logic":"본문 길이 < 250자 AND 항(①~) ≤2 AND 처분키워드 부재 → FP","effect":"FP_FILTER","examples":["G-01-003@민간임대주택에관한특별법","G-01-001@복권및복권기금법"],"rationale":"인용·열거 단편조문에서 단서 2회는 가짜 시그널이며 실질 규율 미약."},{"name":"처분조 단서중첩 TP_BOOST","logic":"본문 =~ /(지정|허가|등록).*취소|업무정지|영업정지/ AND \"다만,\" ≥2 AND 그 중 1개 이상이 \"취소하여야 한다\"(필수취소) → TP_BOOST","effect":"TP_BOOST","examples":["G-01-002@먹는물관리법","G-01-001@산림문화ㆍ휴양에관한법률","G-01-003@부정경쟁방지및영업비밀보호에관한법률","G-01-001@생활물류서비스산업발전법"],"rationale":"제재처분에서 재량+필수취소 단서 중첩은 예측가능성·비례원칙 침해 — 법제처 입안길잡이 결함."},{"name":"권리제한 단서중첩 TP","logic":"본문 =~ /자격|결격|개설|선임|승계/ AND \"다만,\" ≥2 AND \"~할 수 없다|~하지 아니하면\" → TP","effect":"TP_BOOST","examples":["G-01-001@변호사법","G-01-001@발명진흥법","G-01-003@새마을금고법"],"rationale":"수범자 권리·자격 제한 조문의 단서 중첩은 직업의 자유 침해 가능 — 권익위 기준."},{"name":"민사·절차법 단서 FP","logic":"법령명 =~ /민사집행법|민사소송법|상법/ AND 조문 =~ /즉시항고|항소|상고|준용|점유|매수인/ → FP","effect":"FP_FILTER","examples":["G-01-001@민사집행법","G-01-002@상법","G-01-012@상법"],"rationale":"민사절차법의 권원·면책 단서는 법리상 필수이며 침익적 행정결함 아님."},{"name":"필수취소+재량취소 병기 TP","logic":"한 항 안에 \"취소할 수 있다\" + 단서 \"~경우에는 취소하여야 한다\" 동시 출현 → TP","effect":"TP_BOOST","examples":["G-01-001@생활물류서비스산업발전법","G-01-001@법학전문대학원설치ㆍ운영에관한법률","G-01-001@산림문화ㆍ휴양에관한법률"],"rationale":"재량·기속 처분의 혼합 단서는 적용기준 모호 — 감사원 내부통제 결함 유형."}],"missed_patterns":[{"name":"필수취소단서+결격사유 호번호 다중참조","logic":"\"제1호.*제○호.*해당하는 경우에는.*취소하여야 한다\" 단서에 인용호 ≥3","examples":["「먹는물관리법」 §43","「변호사법」 §21의2","「새마을금고법」 §21"]},{"name":"단서 안에 또다른 단서(이중예외)","logic":"단서 본문 중 \"다만\" 재출현 OR \"그러하지 아니하다\" 뒤에 또 \"다만\"","examples":["「상표법」 §98","「상속세및증여세법」 §31","「산지관리법」 §39"]},{"name":"단서로 권한 위임(단서 안에 대통령령)","logic":"\"다만,.*대통령령으로 정하는.*경우에는\" 패턴 → 위임범위 모호","examples":["「물품관리법」 §35","「보험업법」 §125","「산지관리법」 §27"]},{"name":"동의·통지 의제단서","logic":"\"공고|게시.*갈음할 수 있다\" + \"동의를 받기 어려운\" 단서 → 절차생략","examples":["「산림자원의조성및관리에관한법률」 §22"]},{"name":"준용+단서로 적용배제","logic":"\"제○조부터 제○조까지 준용한다. 다만,~ 적용하지 아니한다\" → 추적 불가","examples":["「산업입지및개발에관한법률」 §39","「법인세법」 §62의2"]}]}
