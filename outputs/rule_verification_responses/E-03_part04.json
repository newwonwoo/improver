"new_signals":[
{"name":"동일 조에 전자대안 공존 → 서면 다운그레이드","logic":"서면/우편 키워드 매칭 조에 '정보통신망|전자문서|전자서명|인터넷 홈페이지|전자적 방법' 동시 출현 시 FP","effect":"FP_FILTER","examples":["E-03-001@어선원및어선재해보상보험법","E-03-002@정당법","E-03-003@본인서명사실확인등에관한법률","E-03-014@군사법원법","E-03-008@공공단체등위탁선거에관한법률"],"rationale":"본문에 이미 전자대안이 병기되면 아날로그 잔재 아님, 키워드 단독매칭 오탐."},
{"name":"준용·연동 조문 서면키워드","logic":"본문 '준용한다|~의 규정은' AND 자체 서면의무 부재 OR '민사집행법|부동산등기법|국세기본법.{0,10}준용'","effect":"FP_FILTER","examples":["E-03-015@형사소송법","E-03-006@가족관계의등록등에관한법률","E-03-005@국민건강보험법","E-03-006@공무원범죄에관한몰수특례법","E-03-002@국가통합교통체계효율화법"],"rationale":"준용·타법연동 조문은 서면의무 본체가 아니므로 독립 개선대상 아님."},
{"name":"침익처분 절차 문서통지 → 절차보장","logic":"'압류|취소|이행강제금|변상판정|계고' AND ('문서로|서면으로') 통지","effect":"FP_FILTER","examples":["E-03-006@국민건강보험법","E-03-001@교통약자의이동편의증진법","E-03-002@감사원법","E-03-001@국민연금법"],"rationale":"침익처분 사전 문서통지는 절차적 권리보장이라 제거대상 아님."}
],
"missed_patterns":[
{"name":"서면+구두 등 복수수단 중 전자 누락","logic":"'서면 또는 구두' 등 비전자 복수수단 허용하나 전자수단만 빠진 경우","examples":["「국민기초생활보장법」 §38"]},
{"name":"내용증명우편 효력기산 단일매체","logic":"'내용증명우편으로 발송' AND 효력발생 기산, 전자대안 부재","examples":["「한국주택금융공사법」 §27"]}
]}
