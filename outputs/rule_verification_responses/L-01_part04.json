{"bundle_id":"L-01_part04","rule_id":"L-01","verdicts":[{"fid":"L-01-001@대한민국과아메리카합중국간의상호방위조약제4조에의한시설과구역및대한민국에서의합중국군대의지위에관한협정의실시에따른관세법등의임시특례에관한법률","v":"FP","ev":"목적조 적용대상 법률 열거"},{"fid":"L-01-004@도시공업지역의관리및활성화에관한특별법","v":"FP","ev":"규제 특례 — 각호 분리 열거"},{"fid":"L-01-002@도시공원및녹지등에관한법률","v":"FP","ev":"허가대상 각목 구조 분리"},{"fid":"L-01-005@도시재정비촉진을위한특별법","v":"FP","ev":"감면대상 각호 분리 열거"},{"fid":"L-01-002@도심복합개발지원에관한법률","v":"FP","ev":"통합심의 위원회 각호 열거"},{"fid":"L-01-001@도심융합특구조성및육성에관한특별법","v":"FP","ev":"정의조 — 연계사업 각목 분리"},{"fid":"L-01-006@도심융합특구조성및육성에관한특별법","v":"BORDER","ev":"규제샌드박스 근거 5개 법 병렬"},{"fid":"L-01-001@독립유공자예우에관한법률","v":"TP","ev":"한 단서에 5개법 평문 나열"},{"fid":"L-01-001@독점규제및공정거래에관한법률","v":"FP","ev":"정의조 — 분산 인용"},{"fid":"L-01-002@동물보호법","v":"FP","ev":"승계절차 각호 분리"},{"fid":"L-01-001@디지털포용법","v":"FP","ev":"지원대상 각호 분리"},{"fid":"L-01-001@마약류관리에관한법률","v":"TP","ev":"제3항제3호 한 호에 5개법 평문"},{"fid":"L-01-001@문화예술교육지원법","v":"FP","ev":"정의조 — 각목 분리"},{"fid":"L-01-001@물순환촉진및지원에관한법률","v":"FP","ev":"정의조 시설 각목 분리"},{"fid":"L-01-002@물순환촉진및지원에관한법률","v":"BORDER","ev":"한 항에 다수 인용 가능성"},{"fid":"L-01-001@물환경보전법","v":"FP","ev":"정의조 — 분산 인용"},{"fid":"L-01-003@미래자동차부품산업의전환촉진및생태계육성에관한특별법","v":"FP","ev":"기관 각호 분리"},{"fid":"L-01-001@미술진흥법","v":"FP","ev":"정의조 — 분산"},{"fid":"L-01-003@민간인통제선이북지역의산지관리에관한특별법","v":"FP","ev":"각호 시설 분리 열거"},{"fid":"L-01-001@민사소송등인지법","v":"FP","ev":"인지액 각호 분리"},{"fid":"L-01-002@발달장애인권리보장및지원에관한법률","v":"FP","ev":"복지서비스 각호 분리"},{"fid":"L-01-002@발명진흥법","v":"FP","ev":"지원대상 각호 분리"},{"fid":"L-01-001@방송통신발전기본법","v":"FP","ev":"주요사업자 각호 분리"},{"fid":"L-01-001@방위사업법","v":"FP","ev":"청렴서약 — 분산 인용"},{"fid":"L-01-001@범죄수익은닉의규제및처벌등에관한법률","v":"FP","ev":"벌칙·정의 — 각목 분리"},{"fid":"L-01-001@법령정보의관리및제공에관한법률","v":"FP","ev":"정의조 각목 분리"},{"fid":"L-01-002@법원조직법","v":"FP","ev":"심판권 예외 각목 분리"},{"fid":"L-01-004@법원조직법","v":"FP","ev":"사법보좌관 업무 각호"},{"fid":"L-01-006@법인세법","v":"FP","ev":"중간예납 예외 각목"},{"fid":"L-01-001@보호관찰등에관한법률","v":"FP","ev":"통보대상 각목 분리"},{"fid":"L-01-001@보훈보상대상자지원에관한법률","v":"TP","ev":"제2항 본문에 5개법 평문"},{"fid":"L-01-002@보훈보상대상자지원에관한법률","v":"TP","ev":"제3항 괄호 내 5개법 평문"},{"fid":"L-01-001@부가가치세법","v":"FP","ev":"자료제출 — 각호 분리"},{"fid":"L-01-001@부동산개발사업관리등에관한법률","v":"FP","ev":"정의조 각목 분리"},{"fid":"L-01-001@부동산거래신고등에관한법률","v":"FP","ev":"신고 — 분산 인용"},{"fid":"L-01-001@부동산투자회사법","v":"FP","ev":"정의조 각목 분리"},{"fid":"L-01-001@부패재산의몰수및회복에관한특례법","v":"BORDER","ev":"단편 조문 — 맥락 부족"},{"fid":"L-01-005@사회보장급여의이용ㆍ제공및수급권자발굴에관한법률","v":"FP","ev":"각호 분리 열거"},{"fid":"L-01-001@산림조합법","v":"TP","ev":"제1항 본문 평문에 4개법 나열"},{"fid":"L-01-005@산업입지및개발에관한법률","v":"FP","ev":"적용특례 항·각호 분리"},{"fid":"L-01-007@산업집적활성화및공장설립에관한법률","v":"FP","ev":"산학융합 — 분산 인용"},{"fid":"L-01-002@산지관리법","v":"FP","ev":"행위제한 각호 분리"},{"fid":"L-01-001@생물다양성보전및이용에관한법률","v":"FP","ev":"지역 각호 분리"},{"fid":"L-01-001@석면안전관리법","v":"TP","ev":"제1항 본문에 5개법 평문"},{"fid":"L-01-003@석유및석유대체연료사업법","v":"FP","ev":"세무 — 항·호 분리"},{"fid":"L-01-001@선박관리산업발전법","v":"FP","ev":"인증센터 각호 분리"},{"fid":"L-01-001@선박법","v":"FP","ev":"적용제외 각호 분리"},{"fid":"L-01-001@선박의입항및출항등에관한법률","v":"FP","ev":"정의조 각목 분리"},{"fid":"L-01-008@소득세법","v":"FP","ev":"자료 각호 분리"},{"fid":"L-01-001@소방공무원법","v":"FP","ev":"신규채용 각호 분리"}],"new_signals":[{"name":"정의조문_다중인용_FP","logic":"조문제목=~/^정의$/ AND (조문본문=~/말한다\\.?\\s*$/ 또는 '란.*말한다' 패턴 ≥3) AND 인용법률이 각호/각목으로 분산 → FP_FILTER","effect":"FP_FILTER","examples":["L-01-001@도심융합특구조성및육성에관한특별법","L-01-001@문화예술교육지원법","L-01-001@미술진흥법","L-01-001@부동산투자회사법","L-01-001@물환경보전법"],"rationale":"정의 조문은 각 호별 다른 법률 차용이 본질적 구조이며 독해곤란 아님"},{"name":"각호각목_분산_FP","logic":"한 조문 내 인용법률 총수 N≥5 AND 동일 항/호/목 단위로 분산(한 문단당 인용법률 ≤2) → FP_FILTER","effect":"FP_FILTER","examples":["L-01-002@동물보호법","L-01-004@도시공업지역의관리및활성화에관한특별법","L-01-005@도시재정비촉진을위한특별법","L-01-001@민사소송등인지법","L-01-001@선박법"],"rationale":"각호 구조 분리 열거는 법제처 입안기준상 정상 — 평문 누적이 아님"},{"name":"단일문장_5법이상_TP","logic":"한 문장(마침표 사이) 또는 한 단서 내에 인용법률 ≥4개 평문 나열(각호 구조 없음) → TP_BOOST","effect":"TP_BOOST","examples":["L-01-001@독립유공자예우에관한법률","L-01-001@마약류관리에관한법률","L-01-001@보훈보상대상자지원에관한법률","L-01-001@석면안전관리법","L-01-001@산림조합법"],"rationale":"실제 독해 부담은 한 문장에 다수 법률이 평문으로 묶인 경우에 발생"},{"name":"다른법률과의관계_조문_BORDER","logic":"조문제목=~/다른 법률과의 관계|적용특례|적용제외|적용배제/ AND 인용법률 ≥5 → BORDER 또는 가중치 하향","effect":"FP_FILTER","examples":["L-01-001@석면안전관리법","L-01-005@산업입지및개발에관한법률","L-01-001@선박법"],"rationale":"이런 조문은 입법 목적상 외부 법률 다수 인용이 필수 — 단순 카운트로 결함 판단 불가"},{"name":"통합심의_위원회_나열_FP","logic":"조문에 '통합심의|간주|의제' 키워드 AND 인용법률이 위원회·계획 단위로 1:1 매핑 → FP_FILTER","effect":"FP_FILTER","examples":["L-01-002@도심복합개발지원에관한법률","L-01-005@산업입지및개발에관한법률"],"rationale":"의제·통합심의는 관련법별 위원회 명시가 필수적 — 단순화 불가"},{"name":"벌칙죄종_각목_FP","logic":"인용법률이 형법·특별법상 죄명을 각목으로 나열(범죄수익·보호관찰 등) → FP_FILTER","effect":"FP_FILTER","examples":["L-01-001@범죄수익은닉의규제및처벌등에관한법률","L-01-001@보호관찰등에관한법률","L-01-002@법원조직법"],"rationale":"죄종 열거는 죄형법정주의상 구체 명시 필요"}],"missed_patterns":[{"name":"법률명_자체_과도장문","logic":"법률명 글자수 ≥30 (예: '대한민국과아메리카합중국간의상호방위조약…')이 본문에 등장 → 약칭 미사용 결함","examples":["「대한민국과아메리카합중국간의상호방위조약제4조에의한시설과구역및대한민국에서의합중국군대의지위에관한협정의실시에따른관세법등의임시특례에관한법률」 §1"]},{"name":"동일법률_반복인용","logic":"한 조문 내 동일 법률명이 3회 이상 반복(예: '「국토의 계획 및 이용에 관한 법률」' 4회) → 약칭 도입 결함","examples":["「도시공업지역의관리및활성화에관한특별법」 §53","「산업입지및개발에관한법률」 §23"]},{"name":"외부법조문_연쇄참조","logic":"인용법률 A § → A 시행령 § → 다른 법 B § 의 3단 연쇄가 한 항에 존재 → 추적곤란","examples":["「마약류관리에관한법률」 §6③3","「범죄수익은닉의규제및처벌등에관한법률」 §2"]},{"name":"개정이력_과다누적","logic":"조문 머리·항 머리에 <개정 …> 일자가 5개 이상 → 사실상 통합개정 필요 신호","examples":["「독점규제및공정거래에관한법률」 §2","「물환경보전법」 §2","「발달장애인권리보장및지원에관한법률」 §18"]},{"name":"이중부칙_혼재","logic":"본조 외 부칙 단서로 별도 시행시점 조문이 본문에 노출 → 가독성 결함","examples":["「대한민국과아메리카합중국…임시특례에관한법률」 §1"]}]}
