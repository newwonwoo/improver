  "new_signals": [
    {
      "name": "절차법(소송·집행·비송) 권리제한 FP",
      "logic": "법령명이 '민사소송법|민사집행법|비송사건절차법|군사법원법' OR 조문제목에 '관할|재심|매각기일|재매각|감독|열람·복사' AND 본문 '불복할 수 없다|할 수 없다' → FP_FILTER",
      "effect": "FP_FILTER",
      "examples": ["F-01-001@민사소송법", "F-01-065@민사소송법", "F-01-016@민사집행법", "F-01-020@민사집행법", "F-01-015@비송사건절차법"],
      "rationale": "절차법의 '할 수 없다'는 소송·집행 진행상 절차효과이지 침익적 행정 권리제한이 아님(F-01 명시 FP)."
    },
    {
      "name": "벌칙조문 인용형 권리제한 FP",
      "logic": "본문이 '제N조[의N]를 위반하여 … 자는 \\d+년 이하의 징역 또는 \\d+(억|천만)원 이하의 벌금에 처한다' 단일문장 → FP_FILTER",
      "effect": "FP_FILTER",
      "examples": ["F-01-007@금융산업의구조개선에관한법률"],
      "rationale": "벌칙조문은 제재근거 자체이므로 권리제한 결함 매칭은 오탐."
    },
    {
      "name": "조세·재무 계산규정 및 수익적 재량 FP",
      "logic": "법령명 '국세기본법|법인세법' OR 조문제목 '과세표준|사업연도|기한의 연장' AND 본문 '연장할 수 있다|공제|신고하여야 한다' AND 처분·금지 부재 → FP_FILTER",
      "effect": "FP_FILTER",
      "examples": ["F-01-002@국세기본법", "F-01-003@법인세법", "F-01-002@법인세법"],
      "rationale": "조세 계산·신고규정과 기한연장 수익적 재량은 침익적 권리제한이 아님."
    },
    {
      "name": "처분조 취소+재진입제한 TP 부스트",
      "logic": "조문제목 '허가의 취소|등록취소|인정취소' AND 본문 '취소하여야 한다' 기속단서 AND '취소된 날부터 N년 … 신청할 수 없다|다시 … 아니 된다' → TP_BOOST",
      "effect": "TP_BOOST",
      "examples": ["F-01-008@낚시관리및육성법", "F-01-002@도시교통정비촉진법", "F-01-002@문학진흥법"],
      "rationale": "제재처분에 더해 재진입까지 제한하는 강한 침익규정으로 권리제한 실질이 명확."
    }
  ],
  "missed_patterns": [
    {
      "name": "정책의무·진흥조항의 제재공백",
      "logic": "조문제목에 '진흥|촉진|육성|조성' AND 본문 '하여야 한다|촉진하여야 한다' AND 위반 제재 부재 → 제재공백(F-01 FP, 별도 분류 필요)",
      "examples": ["「데이터산업진흥및이용촉진에관한기본법」 §17", "「농어촌전기공급사업촉진법」 §6"]
    },
    {
      "name": "행위금지(~하여서는 아니 된다)인데 본조 제재 미연계",
      "logic": "본문 '하여서는 아니 된다|할 수 없다' 금지규범 AND 같은 조 내 벌칙·과태료·취소 참조 부재",
      "examples": ["「노동조합및노동관계조정법」 §63", "「보험업법」 §102의3", "「데이터산업진흥및이용촉진에관한기본법」 §12"]
    }
  ]
