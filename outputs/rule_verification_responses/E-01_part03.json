  "new_signals": [
    {
      "name": "pure_enumeration_filter",
      "logic": "조문이 '다음 각 호의 사항을 포함' 또는 '다음 각 호의 사유' 형태로 단순 열거만 하고 단서(다만/단)·중첩 목(가나다)·교차참조가 없으면 중첩 아님",
      "effect": "FP_FILTER",
      "examples": ["E-01-017@임업및산촌진흥촉진에관한법률", "E-01-012@주택법", "E-01-031@하도급거래공정화에관한법률", "E-01-001@학술진흥법", "E-01-024@해운법"],
      "rationale": "기본계획 포함사항·결격사유·정의 등 평면 열거는 조건 분기가 아니라 항목 나열에 불과"
    },
    {
      "name": "danseo_with_subitems_boost",
      "logic": "본문에 '다만' 단서가 존재하고 동시에 호(號) 아래 목(가/나/다) 하위 분기가 있으면 진성 조건 중첩",
      "effect": "TP_BOOST",
      "examples": ["E-01-002@인적자원개발기본법", "E-01-026@저작권법", "E-01-022@협동조합기본법", "E-01-081@지방세특례제한법"],
      "rationale": "단서 예외+목 단계 분기는 실제 조건 트리 깊이 3 이상 보장"
    },
    {
      "name": "cross_reference_chain",
      "logic": "조문 내 '제N조제M항제K호' 형태 교차참조가 2회 이상 등장하면 실질 중첩도 가중",
      "effect": "TP_BOOST",
      "examples": ["E-01-010@전기통신사업법", "E-01-033@폐기물관리법"],
      "rationale": "교차참조는 조건 체인이 다른 조문까지 확장되므로 단순 호 수보다 복잡성 가중치 부여"
    },
    {
      "name": "procedural_article_filter",
      "logic": "조문 제목이 '청문/통지/방식/서명/공시/공표' 등 절차 일회성 행위이고 호가 행위 대상 목록인 경우 FP 가중",
      "effect": "FP_FILTER",
      "examples": ["E-01-072@항공안전법", "E-01-007@형사소송법", "E-01-076@특허법"],
      "rationale": "절차 조문은 행위주체·대상 열거에 가까워 조건 분기로 보기 어려움"
    },
    {
      "name": "definition_article_exclude",
      "logic": "조문 제목 또는 첫 항이 '정의' 또는 '용어의 뜻'이면 호 개수와 무관하게 중첩 아님",
      "effect": "FP_FILTER",
      "examples": ["E-01-001@학술진흥법"],
      "rationale": "정의 조항은 본질적으로 평면 열거"
    }
  ],
