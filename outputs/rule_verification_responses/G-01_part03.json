  "new_signals": [
    {
      "name": "벌칙조문 단서 FP 필터",
      "logic": "조문제목 ~= /벌칙|과태료|징역|벌금/ AND 단서가 '몰수할 수 없을 때|이익 산정 곤란' 류 → FP",
      "effect": "FP_FILTER",
      "examples": ["G-01-003@국가기간전력망확충특별법", "G-01-010@도시개발법"],
      "rationale": "벌칙조문 단서는 권리제한 완화 또는 산정기술 규정으로, 입안길잡이 결함 아님"
    },
    {
      "name": "별항 단서 분산 = 통상구조",
      "logic": "단서 2회가 서로 다른 항(예: ①항·③항)에 분산 AND 동일 절차 내 중첩 아닐 때 → FP",
      "effect": "FP_FILTER",
      "examples": ["G-01-002@국가인권위원회법", "G-01-007@국회법", "G-01-006@군사법원법"],
      "rationale": "법제처 입안길잡이는 한 항 내 단서 중첩만 결함—별항 단서는 정상 입법기술"
    },
    {
      "name": "동일항 내 단서 + '다만'·'단' 키워드 중첩 TP",
      "logic": "한 항(項) 텍스트에 '다만,' 2회 이상 출현 OR '다만,...다만,' 직렬 → TP_BOOST",
      "effect": "TP_BOOST",
      "examples": ["G-01-001@남극활동및환경보호에관한법률", "G-01-001@국가재정법"],
      "rationale": "감사원 내부통제 가이드는 동일 항 내 단서 직렬을 가독성 결함으로 명시"
    },
    {
      "name": "경미사항 단서 + 위임 중첩",
      "logic": "단서 텍스트 ~= /대통령령으로 정하는 경미한 사항/ 2개 항 이상 OR 같은 조문 내 '경미한 사항' 3회 이상 → TP_BOOST",
      "effect": "TP_BOOST",
      "examples": ["G-01-001@국가통합교통체계효율화법", "G-01-010@국토의계획및이용에관한법률", "G-01-001@도로법"],
      "rationale": "권익위 규제개혁은 '경미사항' 반복위임을 시행령 비대화 신호로 분류"
    },
    {
      "name": "수익적 예외 단서 FP",
      "logic": "단서 텍스트 ~= /면제|감면|제외|연장|완화|특례/ AND 침익적 처분 아닐 때 → FP",
      "effect": "FP_FILTER",
      "examples": ["G-01-007@국가유공자등예우및지원에관한법률", "G-01-001@대체역의편입및복무등에관한법률"],
      "rationale": "수익적 재량은 권리확장으로 G-01 대상 아님"
    },
    {
      "name": "정의·자격조문 단서 FP",
      "logic": "조문제목 ~= /정의|자격|적용범위|초임|구성/ AND 단서가 '제외한다|포함한다' 류 → FP",
      "effect": "FP_FILTER",
      "examples": ["G-01-002@국세기본법", "G-01-003@군인사법", "G-01-006@농업협동조합법"],
      "rationale": "정의·자격 단서는 범위 명확화로 입법결함 아님"
    },
    {
      "name": "심의생략·협의생략 단서 TP",
      "logic": "단서 ~= /심의를 거치지 아니할 수 있다|협의를 거치지 아니할 수 있다|절차를 생략할 수 있다/ 2회 이상 → TP_BOOST",
      "effect": "TP_BOOST",
      "examples": ["G-01-002@국가연구개발혁신법", "G-01-002@국토의계획및이용에관한법률"],
      "rationale": "행정절차 통제 우회 단서 중첩은 권익위 절차통제 결함으로 분류"
    }
  ],
