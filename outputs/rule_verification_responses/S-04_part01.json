  "new_signals": [
    {
      "name": "인허가의제_조문_특수성",
      "logic": "조문제목 정규식 /(다른\\s*법(률|령)에\\s*따른\\s*)?인\\s*[ㆍ·]?\\s*허가(등)?(의)?\\s*의제/ AND 호 본문에 「.*」 §N 인용 ≥ 0.7 → S-04 점수 -0.5 (제도설계상 불가피)",
      "effect": "FP_FILTER",
      "examples": ["S-04-001@공공기관지방이전에따른혁신도시건설및지원에관한특별법", "S-04-005@공공주택특별법", "S-04-003@새만금사업추진및지원에관한특별법", "S-04-001@온천법", "S-04-002@도로법"],
      "rationale": "법제처 입안길잡이상 인허가의제 조문은 관계법령 망라가 본질이며 호 개수만으로 결함 판정 불가. 단 50개 초과는 BORDER 유지."
    },
    {
      "name": "정의조문_FP_필터",
      "logic": "조문제목에 '정의' 포함 AND (각 호 끝 '~말한다' 비율 ≥ 0.6 OR 첫 줄 정규식 /이\\s*법에서\\s*사용하는\\s*용어/) → S-04 FP 처리",
      "effect": "FP_FILTER",
      "examples": ["S-04-001@저작권법", "S-04-001@건축법", "S-04-001@대기환경보전법", "S-04-001@주택법", "S-04-001@수산업법"],
      "rationale": "정의조항은 용어 정의의 망라성 자체가 가치이며 분리하면 인용 혼란. 법제처 표준."
    },
    {
      "name": "벌칙_과태료_위반호_FP",
      "logic": "조문제목 정규식 /^(벌칙|과태료|징계|허가의?\\s*취소|등록의?\\s*취소|영업정지)/ AND 각 호에 '제N조...를 위반' 또는 '~한 자' 비율 ≥ 0.7 → FP",
      "effect": "FP_FILTER",
      "examples": ["S-04-019@자본시장과금융투자업에관한법률", "S-04-002@건축물관리법", "S-04-006@공직선거법", "S-04-006@축산법", "S-04-001@경비업법", "S-04-001@농약관리법"],
      "rationale": "위반행위 열거는 죄형법정주의·명확성원칙상 필연. 명확하게 끊어내야 권리보호."
    },
    {
      "name": "공공기관_사업범위_FP",
      "logic": "조문제목 ∈ {사업, 업무, 정관, 회계의 세입} AND (모기관 = 공단/원/기금/공사) → 망라적 권능 부여 목적, FP",
      "effect": "FP_FILTER",
      "examples": ["S-04-003@교육시설등의안전및유지관리등에관한법률", "S-04-001@국립공원공단법", "S-04-002@국립생태원의설립및운영에관한법률", "S-04-001@국립대학법인인천대학교설립ㆍ운영에관한법률", "S-04-001@환경정책기본법"],
      "rationale": "공공기관법에서 사업·업무 열거는 권한 범위를 분명히 하기 위한 입법기술."
    },
    {
      "name": "계획포함사항_TP_부스트",
      "logic": "조문 본문 정규식 /다음\\s*각\\s*호의\\s*사항이?\\s*포함되어야\\s*한다/ AND 조문제목에 '계획' 포함 AND 호 ≥ 15 AND '대통령령으로 정하는 사항' 캐치올 호 존재 → TP 부스트(과잉 포괄위임 결합)",
      "effect": "TP_BOOST",
      "examples": ["S-04-003@도시공업지역의관리및활성화에관한특별법", "S-04-001@경제자유구역의지정및운영에관한특별법", "S-04-003@노후계획도시정비및지원에관한특별법", "S-04-001@도심복합개발지원에관한법률", "S-04-001@과학기술기본법"],
      "rationale": "계획수립 의무의 호가 15개 넘으면서 캐치올 위임까지 두면 실무 가중. S-02와 교차신호."
    },
    {
      "name": "타법명_단순열거_FP",
      "logic": "각 호 내용이 「법령명」만으로 구성된 비율 ≥ 0.8 → 분류 목적, FP",
      "effect": "FP_FILTER",
      "examples": ["S-04-002@조세특례제한법"],
      "rationale": "법령목록 자체가 규정 효과(예: 조세특례 한정)이므로 분할 무의미."
    },
    {
      "name": "캐치올_그밖에_위임_플래그",
      "logic": "마지막 호 정규식 /그\\s*밖에.*대통령령으로\\s*정하/ AND 직전 호 ≥ 15 → S-02와 교차 점수 +",
      "effect": "TP_BOOST",
      "examples": ["S-04-001@도심복합개발지원에관한법률", "S-04-003@노후계획도시정비및지원에관한특별법", "S-04-001@경제자유구역의지정및운영에관한특별법"],
      "rationale": "권익위 규제개혁 가이드: 다수열거+포괄위임 결합은 예측가능성 침해."
    }
  ],
