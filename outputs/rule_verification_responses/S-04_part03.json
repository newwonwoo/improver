{"bundle_id":"S-04_part03","rule_id":"S-04","verdicts":[{"fid":"S-04-003@공동주택관리법","v":"BORDER","ev":"제10호 포괄위임 가능"},{"fid":"S-04-003@공무원재해보상법","v":"BORDER","ev":"제10호 대통령령 위임"},{"fid":"S-04-002@공인중개사법","v":"TP","ev":"재량처분 사유 11개"},{"fid":"S-04-003@공인중개사법","v":"TP","ev":"업무정지 사유 14개"},{"fid":"S-04-002@공인회계사법","v":"FP","ev":"본문 파편(인용조문)"},{"fid":"S-04-004@공직선거법","v":"FP","ev":"불보전 비용 한정열거"},{"fid":"S-04-001@공직선거법","v":"FP","ev":"등록무효 한정열거 명확"},{"fid":"S-04-001@공직자등의병역사항신고및공개에관한법률","v":"FP","ev":"신고의무자 한정열거"},{"fid":"S-04-001@과학기술분야정부출연연구기관등의설립ㆍ운영및육성에관한법률","v":"FP","ev":"정관 표준 기재사항"},{"fid":"S-04-003@관세법","v":"FP","ev":"납세의무자 한정열거"},{"fid":"S-04-004@교육시설등의안전및유지관리등에관한법률","v":"FP","ev":"정관 표준 기재사항"},{"fid":"S-04-001@구직자취업촉진및생활안정지원에관한법률","v":"FP","ev":"본문 파편 인용"},{"fid":"S-04-001@국가연구개발혁신법","v":"FP","ev":"정의조문 열거"},{"fid":"S-04-002@국가유공자등단체설립에관한법률","v":"TP","ev":"수익사업 정지/취소 14개"},{"fid":"S-04-001@국가유산영향진단법","v":"FP","ev":"정의조문 한정열거"},{"fid":"S-04-002@국가인권위원회법","v":"FP","ev":"각하사유 한정열거"},{"fid":"S-04-001@국가자원안보특별법","v":"FP","ev":"정의조문 한정열거"},{"fid":"S-04-001@국내입양에관한특별법","v":"FP","ev":"정의조문 한정열거"},{"fid":"S-04-001@국립대학병원설치법","v":"FP","ev":"정관 표준 기재사항"},{"fid":"S-04-001@국립대학의회계설치및재정운영에관한법률","v":"FP","ev":"세입항목 한정열거"},{"fid":"S-04-001@국립소방병원의설립및운영에관한법률","v":"FP","ev":"정관 표준 기재사항"},{"fid":"S-04-002@국립소방병원의설립및운영에관한법률","v":"BORDER","ev":"제10호 포괄위임"},{"fid":"S-04-001@국립해양과학관의설립및운영에관한법률","v":"FP","ev":"정관 표준 기재사항"},{"fid":"S-04-002@국민연금법","v":"BORDER","ev":"제10·11호 포괄위임"},{"fid":"S-04-001@국방ㆍ군사시설사업에관한법률","v":"BORDER","ev":"제11호 대통령령 위임"},{"fid":"S-04-001@국어기본법","v":"FP","ev":"기본계획 표준항목"},{"fid":"S-04-002@국제항해선박등에대한해적행위피해예방에관한법률","v":"FP","ev":"벌칙 죄형법정주의"},{"fid":"S-04-003@군사법원법","v":"FP","ev":"본문 파편 인용"},{"fid":"S-04-001@군사법원법","v":"FP","ev":"공판조서 기재요건"},{"fid":"S-04-001@군형법","v":"FP","ev":"본문 파편 벌칙"},{"fid":"S-04-004@규제자유특구및지역특화발전특구에관한규제특례법","v":"BORDER","ev":"제10호 포괄위임"},{"fid":"S-04-002@기부금품의모집ㆍ사용및기부문화활성화에관한법률","v":"TP","ev":"등록말소 재량처분 10개"},{"fid":"S-04-001@기업구조조정촉진법","v":"FP","ev":"심의의결사항 한정"},{"fid":"S-04-001@기업활동규제완화에관한특별조치법","v":"FP","ev":"안전관리자 의제목록"},{"fid":"S-04-002@기후위기대응을위한탄소중립ㆍ녹색성장기본법","v":"BORDER","ev":"제11호 포괄위임"},{"fid":"S-04-001@남북교류협력에관한법률","v":"TP","ev":"승인취소 재량처분 11개"},{"fid":"S-04-002@남북교류협력에관한법률","v":"BORDER","ev":"제10호 포괄위임"},{"fid":"S-04-002@노인복지법","v":"FP","ev":"취업제한기관 한정열거"},{"fid":"S-04-004@농약관리법","v":"FP","ev":"본문 파편(몰수)"},{"fid":"S-04-001@농어촌특별세법","v":"FP","ev":"비과세 한정열거"},{"fid":"S-04-004@농촌공간재구조화및재생지원에관한법률","v":"FP","ev":"시행계획 표준항목"},{"fid":"S-04-003@대기환경보전법","v":"FP","ev":"인허가의제 한정열거"},{"fid":"S-04-007@대기환경보전법","v":"FP","ev":"벌칙 죄형법정주의"},{"fid":"S-04-001@대한소방공제회법","v":"FP","ev":"정관 표준 기재사항"},{"fid":"S-04-001@대한적십자사조직법","v":"FP","ev":"정관 표준 기재사항"},{"fid":"S-04-001@댐건설및주변지역지원등에관한법률","v":"FP","ev":"기본계획 표준항목"},{"fid":"S-04-001@데이터산업진흥및이용촉진에관한기본법","v":"BORDER","ev":"제10호 포괄위임"},{"fid":"S-04-002@도로교통법","v":"FP","ev":"긴급차 특례 한정열거"},{"fid":"S-04-001@도시가스사업법","v":"FP","ev":"정의조문 한정열거"},{"fid":"S-04-004@공직선거법","v":"FP","ev":"불보전비용 한정열거"}],"new_signals":[{"name":"정관기재사항_표준템플릿","logic":"조문제목 =~ /정관/ AND 본문 =~ /정관에는 다음 각 호의 사항이 포함/ AND 호 내용 =~ /^(목적|명칭|주된 사무소|임원|이사회|회계|해산|공고|정관의 변경)/","effect":"FP_FILTER","examples":["S-04-001@국립대학병원설치법","S-04-001@대한적십자사조직법","S-04-001@대한소방공제회법","S-04-004@교육시설등의안전및유지관리등에관한법률","S-04-001@국립소방병원의설립및운영에관한법률"],"rationale":"공공기관 정관 표준 기재사항은 법제처 입안길잡이가 권장하는 정형 패턴으로 10개 이상 열거 불가피"},{"name":"정의조문_용어열거","logic":"조문제목 =~ /^정의$/ AND 본문 =~ /다음과 같다|뜻은 다음과 같다/ AND 호마다 =~ /\"[^\"]+\"(이?란|이라 함은)/","effect":"FP_FILTER","examples":["S-04-001@국가연구개발혁신법","S-04-001@국가자원안보특별법","S-04-001@국내입양에관한특별법","S-04-001@국가유산영향진단법","S-04-001@도시가스사업법"],"rationale":"용어정의는 죄형법정주의·명확성원칙상 한정열거 필수, 호 개수가 많아도 결함 아님"},{"name":"벌칙_죄형법정주의_열거","logic":"조문제목 =~ /벌칙|과태료/ AND 본문 =~ /징역|벌금|과태료/ AND 호 =~ /제\\d+조.*위반/","effect":"FP_FILTER","examples":["S-04-002@국제항해선박등에대한해적행위피해예방에관한법률","S-04-007@대기환경보전법"],"rationale":"형벌·과태료 구성요건은 명확성원칙상 한정열거 필수"},{"name":"기본계획_표준항목_위임","logic":"조문제목 =~ /기본계획|시행계획/ AND 본문 =~ /다음 각 호의 사항이 포함/ AND 마지막호 =~ /그 밖에.*대통령령으로 정하는/","effect":"FP_FILTER","examples":["S-04-001@국어기본법","S-04-004@농촌공간재구조화및재생지원에관한법률","S-04-001@데이터산업진흥및이용촉진에관한기본법","S-04-001@댐건설및주변지역지원등에관한법률"],"rationale":"기본계획 포함사항은 입법관행상 표준 항목이며 호 10개는 통상수준"},{"name":"재량처분사유_열거과다_TP부스트","logic":"본문 =~ /취소할 수 있다|정지를 명할 수 있다|말소할 수 있다/ AND 호 ≥ 10 AND 본문에 청문/사전통지 절차 없음","effect":"TP_BOOST","examples":["S-04-002@공인중개사법","S-04-003@공인중개사법","S-04-002@국가유공자등단체설립에관한법률","S-04-001@남북교류협력에관한법률","S-04-002@기부금품의모집ㆍ사용및기부문화활성화에관한법률"],"rationale":"침익적 재량처분 사유 과다열거는 권익위 규제개혁상 예측가능성 저해로 TP 강화"},{"name":"본문파편_조문리스트누락","logic":"본문 길이 < 200자 AND 호 명시 없음 AND 매칭이 '호 N개'인데 실제 본문에 호 패턴 미존재","effect":"FP_FILTER","examples":["S-04-002@공인회계사법","S-04-003@군사법원법","S-04-001@군형법","S-04-004@농약관리법","S-04-001@구직자취업촉진및생활안정지원에관한법률"],"rationale":"본문 일부만 추출된 파편 매칭은 검증 불가, 룰 매칭 노이즈"},{"name":"최종호_포괄위임_BORDER","logic":"호 개수 ≥ 10 AND 마지막호 =~ /그 밖에.*대통령령으로 정하는/ AND 시행령 매핑 미확인","effect":"NEW_RULE","examples":["S-04-003@공동주택관리법","S-04-003@공무원재해보상법","S-04-002@국민연금법","S-04-001@국방ㆍ군사시설사업에관한법률","S-04-004@규제자유특구및지역특화발전특구에관한규제특례법"],"rationale":"포괄위임 동반 열거는 S-02와 교차신호로 분리 판정 필요"}],"missed_patterns":[{"name":"동일사유_중복열거(가호 다층 중첩)","logic":"호 내부에 '가목', '나목' 등 목 패턴 ≥ 3개이며 전체 목 합계 ≥ 15","examples":["「관세법」 §19①","「국가연구개발혁신법」 §2"]},{"name":"개정연혁_누적열거(15회 이상 개정)","logic":"<개정 ...> 태그 내 날짜 ≥ 15개","examples":["「농어촌특별세법」 §4","「대기환경보전법」 §90"]},{"name":"인허가의제_과다(10개 이상 타법 인용)","logic":"본문 =~ /다음 각 호의.*받은 것으로 본다/ AND 호 ≥ 10 AND 호마다 다른 법률 인용","examples":["「대기환경보전법」 §58의15"]},{"name":"호 번호 분기(N의2, N의3) 다발","logic":"호 패턴에 'N의M' (예: 5의2, 7의2) ≥ 3개 발견","examples":["「농어촌특별세법」 §4","「도시가스사업법」 §2","「대기환경보전법」 §90"]}]}
