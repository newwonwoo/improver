{"bundle_id":"L-01_part02","rule_id":"L-01","verdicts":[{"fid":"L-01-003@자연재해대책법","v":"FP","ev":"내풍설계 대상시설 열거"},{"fid":"L-01-001@재해위험개선사업및이주대책에관한특별법","v":"FP","ev":"인ㆍ허가등 의제조항"},{"fid":"L-01-003@저수지ㆍ댐의안전관리및재해예방에관한법률","v":"FP","ev":"인ㆍ허가등 의제"},{"fid":"L-01-001@전원개발촉진법","v":"FP","ev":"다른 법률과의 관계"},{"fid":"L-01-002@전자정부법","v":"FP","ev":"심사ㆍ승인ㆍ협의 의제"},{"fid":"L-01-001@정부기관및공공법인등의광고시행에관한법률","v":"FP","ev":"정의조항 다른법 차용"},{"fid":"L-01-026@조세특례제한법","v":"FP","ev":"증권거래세 면제 열거"},{"fid":"L-01-004@조세특례제한법","v":"FP","ev":"창업감면 적용법 열거"},{"fid":"L-01-011@조세특례제한법","v":"FP","ev":"감면 대상 농지 등 열거"},{"fid":"L-01-013@조세특례제한법","v":"FP","ev":"고유목적사업법인 열거"},{"fid":"L-01-001@주택임대차보호법","v":"FP","ev":"우선변제승계 금융기관"},{"fid":"L-01-002@중소기업창업지원법","v":"FP","ev":"면제부담금 열거"},{"fid":"L-01-001@지방자치단체보조금관리에관한법률","v":"FP","ev":"연계 정보시스템 열거"},{"fid":"L-01-001@지방자치분권및지역균형발전에관한특별법","v":"FP","ev":"정의조항 다른법 차용"},{"fid":"L-01-002@지방자치분권및지역균형발전에관한특별법","v":"FP","ev":"특례시 사무 열거"},{"fid":"L-01-001@지역농림어업발전사업협력촉진에관한법률","v":"FP","ev":"정의조항 다른법 차용"},{"fid":"L-01-001@청소년보호법","v":"FP","ev":"정의조항 매체물 열거"},{"fid":"L-01-002@친수구역활용에관한특별법","v":"FP","ev":"인ㆍ허가등 의제"},{"fid":"L-01-001@택지개발촉진법","v":"FP","ev":"다른 법률과의 관계"},{"fid":"L-01-001@하도급거래공정화에관한법률","v":"FP","ev":"정의조항 다른법 차용"},{"fid":"L-01-001@하천법","v":"FP","ev":"다른 법률에 의한 의제"},{"fid":"L-01-003@한강수계상수원수질개선및주민지원등에관한법률","v":"FP","ev":"수변구역 설치금지 시설"},{"fid":"L-01-002@해양산업클러스터의지정및육성등에관한특별법","v":"FP","ev":"인가ㆍ허가등 의제"},{"fid":"L-01-001@해양심층수의개발및관리에관한법률","v":"FP","ev":"허가등 의제"},{"fid":"L-01-001@해양치유자원의관리및활용에관한법률","v":"FP","ev":"인가ㆍ허가등 의제"},{"fid":"L-01-001@환경범죄등의단속및가중처벌에관한법률","v":"FP","ev":"정의(오염물질) 다른법 차용"},{"fid":"L-01-002@2018평창동계올림픽대회및동계패럴림픽대회지원등에관한특별법","v":"FP","ev":"부담금 감면 열거"},{"fid":"L-01-001@5ㆍ18민주유공자예우및단체설립에관한법률","v":"FP","ev":"보훈 가점 중복방지 인용"},{"fid":"L-01-001@5ㆍ18민주화운동관련자보상등에관한법률","v":"FP","ev":"다른법 보상 중복 조정"},{"fid":"L-01-002@가족돌봄등위기아동ㆍ청년지원에관한법률","v":"FP","ev":"공공데이터 출처 열거"},{"fid":"L-01-004@감염병의예방및관리에관한법률","v":"FP","ev":"역학조사관 자격 인용"},{"fid":"L-01-002@개별소비세법","v":"FP","ev":"비과세 적용법 열거"},{"fid":"L-01-002@건강기능식품에관한법률","v":"FP","ev":"과징금 자료요청 근거"},{"fid":"L-01-001@건설산업기본법","v":"FP","ev":"보험료 산출내역 인용"},{"fid":"L-01-001@게임산업진흥에관한법률","v":"FP","ev":"정의조항 사행성게임물"},{"fid":"L-01-002@게임산업진흥에관한법률","v":"FP","ev":"자체등급분류 사업자 요건"},{"fid":"L-01-001@경찰공무원법","v":"FP","ev":"결격사유 범죄 인용"},{"fid":"L-01-003@공공단체등위탁선거에관한법률","v":"FP","ev":"위탁단체 근거법 열거"},{"fid":"L-01-001@공공주택특별법","v":"FP","ev":"세제감면 근거법 열거"},{"fid":"L-01-002@공공주택특별법","v":"FP","ev":"사업자 지정 근거법"},{"fid":"L-01-013@공공주택특별법","v":"FP","ev":"벌칙조항 — 권리제한 아님"},{"fid":"L-01-002@공무원재해보상법","v":"FP","ev":"다른법 급여 조정"},{"fid":"L-01-001@공유수면관리및매립에관한법률","v":"FP","ev":"적용배제 다른법 열거"},{"fid":"L-01-002@공유수면관리및매립에관한법률","v":"FP","ev":"방치선박 제거근거 인용"},{"fid":"L-01-003@공유수면관리및매립에관한법률","v":"FP","ev":"점용허가 예외 인용"},{"fid":"L-01-001@공유재산및물품관리법","v":"FP","ev":"공유재산 범위(지식재산권)"},{"fid":"L-01-002@공유재산및물품관리법","v":"FP","ev":"위탁개발 근거법 열거"},{"fid":"L-01-001@공익신탁법","v":"FP","ev":"인가요건 결격사유"},{"fid":"L-01-003@공중위생관리법","v":"FP","ev":"과징금 제외사유 범죄"},{"fid":"L-01-004@공중위생관리법","v":"FP","ev":"폐쇄명령 가중대상 범죄"}],"new_signals":[{"name":"인허가의제조항_FP필터","logic":"조문제목 정규식 r'(다른\\s*법률과의\\s*관계|인[ㆍ·ㅡ]?허가\\s*등의?\\s*의제|허가등의?\\s*의제|심사[ㆍ·]?승인[ㆍ·]?협의의?\\s*의제)' AND 본문 '받은\\s*것으로\\s*본다' 포함","effect":"FP_FILTER","examples":["L-01-001@재해위험개선사업및이주대책에관한특별법","L-01-001@전원개발촉진법","L-01-001@택지개발촉진법","L-01-002@친수구역활용에관한특별법","L-01-001@하천법"],"rationale":"의제조항은 입법기술상 다수 법률 열거 불가피. 법제처 입안길잡이도 이를 인정."},{"name":"정의조항_차용인용_FP필터","logic":"조문제목 '정의' AND 본문 '「.*」.*에\\s*따른' 패턴 ≥5건 AND '말한다' 종결","effect":"FP_FILTER","examples":["L-01-001@정부기관및공공법인등의광고시행에관한법률","L-01-001@청소년보호법","L-01-001@하도급거래공정화에관한법률","L-01-001@환경범죄등의단속및가중처벌에관한법률","L-01-001@지역농림어업발전사업협력촉진에관한법률"],"rationale":"정의차용은 용어 일관성 확보 목적. 다수 인용 자체는 결함이 아님."},{"name":"열거형감면면제_FP필터","logic":"조문제목 정규식 r'(면제|감면|비과세|부담금|세액감면)' AND 호별 항목이 '「.*」\\s*제\\d+조에\\s*따른\\s*\\S+(?:부담금|세|비)' 패턴 다수","effect":"FP_FILTER","examples":["L-01-002@중소기업창업지원법","L-01-002@2018평창동계올림픽대회및동계패럴림픽대회지원등에관한특별법","L-01-002@개별소비세법","L-01-026@조세특례제한법"],"rationale":"감면대상은 개별법상 부담금/세목을 특정해야 하므로 다수 인용 정상."},{"name":"결격사유_범죄인용_FP필터","logic":"조문제목 정규식 r'(결격사유|임용자격|폐쇄명령|영업금지)' AND '벌금|선고|유예|위반하여' 키워드 AND 인용법률 다수가 형사처벌법","effect":"FP_FILTER","examples":["L-01-001@경찰공무원법","L-01-003@공중위생관리법","L-01-004@공중위생관리법","L-01-001@공익신탁법"],"rationale":"결격/제재사유에 범죄근거 열거는 권리제한 명확화 — 법제처 기준 적정."},{"name":"중복수급조정_FP필터","logic":"조문제목 r'(다른\\s*법령?에\\s*따른\\s*급여|보상\\s*등과의?\\s*관계|급여와의?\\s*조정)' AND '빼고\\s*지급|선택' 키워드","effect":"FP_FILTER","examples":["L-01-002@공무원재해보상법","L-01-001@5ㆍ18민주화운동관련자보상등에관한법률"],"rationale":"중복수급 방지를 위해 타법 급여 열거 필수."},{"name":"순수인용밀도_TP_BOOST","logic":"조문제목에 의제/정의/감면/결격/조정 키워드 부재 AND 인용법률 ≥10 AND 본문이 의무·금지·제재 조항","effect":"TP_BOOST","examples":[],"rationale":"위 면제유형이 아닌데도 다수 법률을 한 조문에 압축하면 진짜 독해곤란."}],"missed_patterns":[{"name":"의제조항_관계법령_갱신누락","logic":"의제조항이 최근 5년 개정이력 있는데 인용된 법률 중 폐지·이관된 법명 포함 검출(예: 「전원개발 촉진법」 → 「전원개발촉진법」 표기 불일치)","examples":["「전원개발촉진법」 §6","「재해위험개선사업및이주대책에관한특별법」 §17"]},{"name":"의제효과_협의절차_부재","logic":"인허가의제조항에 '관계 행정기관의 장과 협의' 절차가 별항으로 명시되지 않거나, 협의 미동의 시 처리방법 누락","examples":["「해양심층수의개발및관리에관한법률」 §17","「자연재해대책법」 §20"]},{"name":"정의조항_상위법_변경미반영","logic":"인용된 다른 법률의 조번호와 실제 현행 조번호 불일치(예: 인용 '제2조제1호'가 개정으로 '제3조제1호'로 이동)","examples":["「청소년보호법」 §2","「게임산업진흥에관한법률」 §2"]},{"name":"감면조항_부담금_누락","logic":"창업·재해·올림픽 등 부담금감면 조문에서 현행 시행되는 부담금 16개 중 일부만 열거되어 형평성 결함","examples":["「2018평창동계올림픽대회및동계패럴림픽대회지원등에관한특별법」 §36","「중소기업창업지원법」 §23"]}]}
