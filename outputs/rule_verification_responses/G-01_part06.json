  "new_signals": [
    {
      "name": "타법우선_적용단서",
      "logic": "단서 텍스트에 정규식 '「[^」]+법[^」]*」(에 따른다|이 정하는 바에 따른다|에서 정하는 바에 따른다)' 매칭 시",
      "effect": "FP_FILTER",
      "examples": ["G-01-001@지능정보화기본법", "G-01-001@해양환경관리법", "G-01-003@화재의예방및안전관리에관한법률"],
      "rationale": "타법 우선적용은 법체계 정합성 조항으로 결함 아님"
    },
    {
      "name": "경미사항_위임_절차예외",
      "logic": "단서에 '(경미한 사항|경미한 사유).{0,10}(대통령령|부령|고시).{0,30}(신고|생략|제외|그러하지 아니)' 정규식",
      "effect": "FP_FILTER",
      "examples": ["G-01-001@항공사업법", "G-01-001@해양레저관광진흥법", "G-01-001@환경영향평가법"],
      "rationale": "경미사항 절차완화는 행정부담 경감 목적"
    },
    {
      "name": "정의조항_단서",
      "logic": "조문제목 '(정의)' OR 조문번호 '제2조' AND 본문에 '~란.*말한다|~을 말한다' 패턴",
      "effect": "FP_FILTER",
      "examples": ["G-01-001@하도급거래공정화에관한법률", "G-01-001@중재법", "G-01-001@항공안전법"],
      "rationale": "정의조항의 단서는 개념 한정으로 결함 아님"
    },
    {
      "name": "양벌규정_면책단서",
      "logic": "조문제목 '(양벌규정)' AND 단서에 '상당한 주의와 감독을 게을리하지'",
      "effect": "FP_FILTER",
      "examples": ["G-01-001@풍수해ㆍ지진재해보험법"],
      "rationale": "양벌규정 면책단서는 헌법재판소 결정에 따른 필수조항"
    },
    {
      "name": "취소의무_단서중첩",
      "logic": "단서에 '(취소하여야 한다|해야 한다)' AND 결격사유호 '임원.{0,5}(교체|바꾸어).{0,10}그러하지 아니' 동시 존재",
      "effect": "TP_BOOST",
      "examples": ["G-01-006@하수도법", "G-01-003@환경오염시설의통합관리에관한법률", "G-01-005@친환경농어업육성및유기식품등의관리ㆍ지원에관한법률"],
      "rationale": "필요적 취소 의무 + 임원교체 예외는 처분 예측가능성 저해"
    },
    {
      "name": "감면추징_지역요건_단서중첩",
      "logic": "조세감면 조문 + '(주거지역|상업지역|공업지역).{0,30}편입.{0,50}그러하지' + '(3년|5년).{0,20}양도.{0,20}납부'",
      "effect": "TP_BOOST",
      "examples": ["G-01-023@조세특례제한법", "G-01-045@지방세특례제한법", "G-01-023@지방세특례제한법"],
      "rationale": "단서로 감면배제 및 추징요건 중첩 → 납세자 예측가능성 저해"
    },
    {
      "name": "절차생략_동의기반",
      "logic": "단서에 '(동의|의사에 반하지 아니)' AND '(공고|송달|통보).{0,20}(아니할|생략)'",
      "effect": "FP_FILTER",
      "examples": ["G-01-002@초ㆍ중등교육법", "G-01-016@채무자회생및파산에관한법률"],
      "rationale": "당사자 동의 기반 절차생략은 권익보호와 양립"
    }
  ],
