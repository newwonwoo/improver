  "new_signals": [
    {
      "name": "정의조문 FP 필터",
      "logic": "조문제목 RE '^제\\d+조\\(정의\\)' OR 본문 RE '\"[^\"]+\"(라|이라) 함은.*말한다' 빈도≥3 → E-01 FP",
      "effect": "FP_FILTER",
      "examples": ["E-01-001@영화및비디오물의진흥에관한법률"],
      "rationale": "정의조문의 호·목 중첩은 용어 분기일 뿐 규제 의무 중첩이 아님"
    },
    {
      "name": "벌칙조문 FP 필터",
      "logic": "조문제목 IN {'벌칙','과태료'} OR 본문 RE '(징역|벌금|구류|과료).*처한다' → E-01 FP",
      "effect": "FP_FILTER",
      "examples": ["E-01-001@아동학대범죄의처벌등에관한특례법", "E-01-012@인삼산업법"],
      "rationale": "벌칙은 죄형법정주의상 사유열거가 본질이며 단순 호 나열은 결함 아님"
    },
    {
      "name": "단순 호 열거 FP 필터",
      "logic": "조문 nesting depth = 단일항+단일호레벨(가목/나목 없음) AND 호 개수≥5 → E-01 다운그레이드",
      "effect": "FP_FILTER",
      "examples": ["E-01-030@벤처기업육성에관한특별법", "E-01-013@산업재해보상보험법", "E-01-003@순환경제사회전환촉진법"],
      "rationale": "단순 평면적 열거는 가독성 저해 없음; '조건 중첩'은 항-호-목 다층 깊이여야 함"
    },
    {
      "name": "재량+단서+다중 가중사유 TP_BOOST",
      "logic": "본문 RE '(취소|영업정지).*할 수 있다.*다만.*하여야 한다' AND 호 개수≥6 AND 가목 RE '가\\.' 출현 → TP 상향",
      "effect": "TP_BOOST",
      "examples": ["E-01-022@벤처투자촉진에관한법률", "E-01-030@여신전문금융업법", "E-01-009@음악산업진흥에관한법률"],
      "rationale": "제재처분의 사유 누적+단서 예외는 침익적 재량 남용 위험 (감사원 내부통제 기준)"
    },
    {
      "name": "준용·의제조문 FP 필터",
      "logic": "본문 RE '(준용|적용|본다|의제)' AND '「.*법」' 인용≥3 → E-01 FP",
      "effect": "FP_FILTER",
      "examples": ["E-01-006@물순환촉진및지원에관한법률", "E-01-034@물환경보전법", "E-01-022@여객자동차운수사업법"],
      "rationale": "타법 준용은 입법기술상 불가피한 참조 중첩; 의제조문은 절차간소화 목적"
    },
    {
      "name": "기본계획·조성계획 FP 필터",
      "logic": "조문제목 RE '(기본계획|관리계획|조성계획|사업계획)' AND 본문 RE '다음 각 호의 사항' AND 호 개수≥6 → E-01 다운그레이드",
      "effect": "FP_FILTER",
      "examples": ["E-01-003@순환경제사회전환촉진법", "E-01-007@스마트농업육성및지원에관한법률", "E-01-002@역세권의개발및이용에관한법률", "E-01-002@역사문화권정비등에관한특별법"],
      "rationale": "계획 포함사항 열거는 정책 의무지 침익규제 아님"
    },
    {
      "name": "조세 다단 적용제외 TP_BOOST",
      "logic": "법령명 IN {법인세법,소득세법,상속세및증여세법} AND 본문 RE '다만.*적용하지 아니한다' 출현≥2 AND 호×목 누적 depth≥3 → TP",
      "effect": "TP_BOOST",
      "examples": ["E-01-032@법인세법", "E-01-077@소득세법", "E-01-024@상속세및증여세법"],
      "rationale": "조세회피방지 규정의 다층 단서는 납세자 예측가능성 저해 (감사원 세정감사 지적)"
    },
    {
      "name": "단일항 단문 조문 FP 필터",
      "logic": "조문 전체 라인수≤3 AND 호·목 부재 → E-01 매칭 자동 FP",
      "effect": "FP_FILTER",
      "examples": ["E-01-029@민법", "E-01-011@선박직원법"],
      "rationale": "조문 본문이 1~2문장인데 조건 중첩으로 잡힘은 룰 오작동"
    }
  ],
