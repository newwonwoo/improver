  "new_signals": [
    {
      "name": "양벌규정 면책단서 FP",
      "logic": "조문제목=='양벌규정' AND 본문 includes '상당한 주의와 감독을 게을리하지 아니한'",
      "effect": "FP_FILTER",
      "examples": ["E-01-072@산업안전보건법", "E-01-069@원자력안전법"],
      "rationale": "양벌규정 면책단서는 다단계로 보이나 형사법 정형구문으로 결함 아님"
    },
    {
      "name": "정책의무·진흥 조문 FP",
      "logic": "제목 또는 본문 매치 r'(진흥|육성|촉진|장려).{0,40}(노력하여야|지원할 수|마련하여야)'",
      "effect": "FP_FILTER",
      "examples": ["E-01-002@한의약육성법", "E-01-012@한옥등건축자산의진흥에관한법률", "E-01-005@한식진흥법", "E-01-003@해양수산발전기본법"],
      "rationale": "정책의무·지원조문은 권리침해 없는 수익적 조항"
    },
    {
      "name": "정의·열거조문 FP",
      "logic": "제목 includes '정의' OR 본문 '다음 각 호의 사업/업무를 (수행|한다)' AND 처분/제재 키워드 없음",
      "effect": "FP_FILTER",
      "examples": ["E-01-001@여수ㆍ순천10ㆍ19사건진상규명및희생자명예회복에관한특별법", "E-01-008@식품안전기본법", "E-01-008@시체해부및보존에관한법률", "E-01-001@해외긴급구호에관한법률"],
      "rationale": "용어정의·기관업무 열거는 조건중첩처럼 보이지만 단순 나열"
    },
    {
      "name": "처분조건 다단 중첩 TP_BOOST",
      "logic": "본문에 (시정명령|허가|취소|제한) AND (대통령령으로 정하는) AND 단서('다만') AND 호열거≥3",
      "effect": "TP_BOOST",
      "examples": ["E-01-011@집단에너지사업법", "E-01-024@전통시장및상점가육성을위한특별법", "E-01-005@지역개발및지원에관한법률", "E-01-009@청소년보호법"],
      "rationale": "침익처분에 위임·단서·호열거 동시는 예측가능성 저하 결함"
    },
    {
      "name": "벌칙·예비음모 조항 FP",
      "logic": "제목 includes '벌칙' OR 본문 정규식 r'(\\d+년 이하의 징역|\\d+만원 이하의 벌금)' AND 호열거",
      "effect": "FP_FILTER",
      "examples": ["E-01-002@성폭력범죄의처벌등에관한특례법", "E-01-011@주민소환에관한법률"],
      "rationale": "벌칙조문 호열거는 형법 정형이며 룰 E-01 대상 아님"
    },
    {
      "name": "다른법령 인용·적용관계 FP",
      "logic": "제목 includes '다른 법' OR 본문 매치 r'「[^」]+」.{0,20}(적용|준용|따른다)' 다중",
      "effect": "FP_FILTER",
      "examples": ["E-01-001@해외건설촉진법", "E-01-007@위생용품관리법", "E-01-003@조세범처벌절차법"],
      "rationale": "법률 적용관계·준용 규정은 본문 자체 결함 아님"
    }
  ],
  "missed_patterns": [
    {
      "name": "단서 다중연쇄(다만·다만·이 경우)",
      "logic": "한 항 내 '다만' 또는 '이 경우' ≥2회 출현",
      "examples": ["「상호저축은행법」 §22의4", "「식품위생법」 §18", "「철도안전법」 §74"]
    },
    {
      "name": "위임의 위임(중층 위임)",
      "logic": "본문 매치 r'(대통령령|총리령|부령).+ (대통령령|총리령|부령)' 같은 항에서 2회 이상",
      "examples": ["「청소년보호법」 §29", "「전통시장및상점가육성을위한특별법」 §31"]
    },
    {
      "name": "호열거 + 단서 + 각 호 외 예외",
      "logic": "'다음 각 호' + '단서' + '제○호 외' 동시 출현",
      "examples": ["「소득세법」 §128", "「조세특례제한법」 §76"]
    }
  ]
}
