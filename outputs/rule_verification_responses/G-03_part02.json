{"bundle_id":"G-03_part02","rule_id":"G-03","verdicts":[{"fid":"G-03-021@법원조직법","v":"FP","ev":"소속 직원 지휘·감독(내부)"},{"fid":"G-03-022@법원조직법","v":"FP","ev":"소속 직원 지휘·감독(내부)"},{"fid":"G-03-002@사회적참사의진상규명및안전사회건설등을위한특별법","v":"FP","ev":"소속 직원 지휘·감독(내부)"},{"fid":"G-03-001@상호저축은행법","v":"BORDER","ev":"외부감독+명령권 有, 절차 부재"},{"fid":"G-03-001@생활물류서비스산업발전법","v":"BORDER","ev":"기관간 사무지도감독"},{"fid":"G-03-001@생활체육진흥법","v":"TP","ev":"외부감독 단문, 절차 전무"},{"fid":"G-03-002@석유및석유대체연료사업법","v":"BORDER","ev":"기관간 사무지도감독"},{"fid":"G-03-002@세월호선체조사위원회의설치및운영에관한특별법","v":"FP","ev":"소속 직원 지휘·감독(내부)"},{"fid":"G-03-001@수산업협동조합법","v":"BORDER","ev":"청산사무 한정 감독"},{"fid":"G-03-001@신용협동조합법","v":"BORDER","ev":"청산사무 한정 감독"},{"fid":"G-03-001@신탁법","v":"FP","ev":"법원의 사법감독+처분권"},{"fid":"G-03-001@아시아문화중심도시조성에관한특별법","v":"FP","ev":"위임사무 지휘감독+보고"},{"fid":"G-03-001@일제강점하반민족행위진상규명에관한특별법","v":"FP","ev":"소속 직원 지휘·감독(내부)"},{"fid":"G-03-001@자동차관리법","v":"BORDER","ev":"기관간 사무지도감독"},{"fid":"G-03-001@자율방범대설치및운영에관한법률","v":"BORDER","ev":"행안부령 위임 有"},{"fid":"G-03-001@재외국민의교육지원등에관한법률","v":"FP","ev":"학교장의 내부 관리감독"},{"fid":"G-03-001@정보통신진흥및융합활성화등에관한특별법","v":"FP","ev":"대통령령 위임+준용 有"},{"fid":"G-03-001@정부대표및특별사절의임명과권한에관한법률","v":"FP","ev":"외교교섭 지휘감독(내부)"},{"fid":"G-03-002@정부조직법","v":"FP","ev":"대통령 행정감독권+중지권"},{"fid":"G-03-003@정부조직법","v":"FP","ev":"총리 감독+중지취소권"},{"fid":"G-03-001@정부조직법","v":"FP","ev":"기관장 내부 지휘감독"},{"fid":"G-03-002@제주특별자치도설치및국제자유도시조성을위한특별법","v":"FP","ev":"부시장의 내부 지휘감독"},{"fid":"G-03-001@주택법","v":"TP","ev":"단문 외부감독, 절차 전무"},{"fid":"G-03-003@지방자치법","v":"FP","ev":"하부기관 직원 지휘감독"},{"fid":"G-03-001@지방자치법","v":"FP","ev":"의장의 의회사무 감독"},{"fid":"G-03-001@집합건물의소유및관리에관한법률","v":"FP","ev":"민사단체 자치감독"},{"fid":"G-03-001@친일반민족행위자재산의국가귀속에관한특별법","v":"FP","ev":"소속 직원 지휘·감독(내부)"},{"fid":"G-03-001@특별감찰관법","v":"FP","ev":"감찰관 내부 지휘감독"},{"fid":"G-03-001@한국보훈복지의료공단법","v":"BORDER","ev":"보고·검사권 有, 주기·공개 부재"},{"fid":"G-03-001@항공안전법","v":"FP","ev":"벌칙 조문에서 매칭됨"},{"fid":"G-03-001@헌법재판소법","v":"FP","ev":"소장의 내부 지휘감독"},{"fid":"G-03-002@화물자동차운수사업법","v":"BORDER","ev":"기관간 사무지도감독"},{"fid":"G-03-001@10ㆍ29이태원참사피해자권리보장과진상규명및재발방지를위한특별법","v":"FP","ev":"소위원장 내부 지휘감독"},{"fid":"G-03-001@4ㆍ16세월호참사진상규명및안전사회건설등을위한특별법","v":"FP","ev":"사무처장 내부 지휘감독"},{"fid":"G-03-001@5ㆍ18민주화운동진상규명을위한특별법","v":"FP","ev":"사무처장 내부 지휘감독"},{"fid":"G-03-001@감사원법","v":"FP","ev":"원장의 소속공무원 감독"},{"fid":"G-03-001@건설기계관리법","v":"FP","ev":"호별범위+보고·검사·시정명령"},{"fid":"G-03-002@겨레말큰사전남북공동편찬사업회법","v":"BORDER","ev":"공무원 파견만, 절차 부재"},{"fid":"G-03-001@겨레말큰사전남북공동편찬사업회법","v":"FP","ev":"이사장 내부 지휘감독"},{"fid":"G-03-001@경영지도사및기술지도사에관한법률","v":"BORDER","ev":"보고·검사권 有, 주기 부재"},{"fid":"G-03-001@경찰직무응원법","v":"FP","ev":"대장의 대원 지휘감독(내부)"},{"fid":"G-03-001@고등교육법","v":"FP","ev":"규제특례+법령정비+취소권"},{"fid":"G-03-001@고위공직자범죄수사처설치및운영에관한법률","v":"FP","ev":"처장 내부 지휘감독"},{"fid":"G-03-001@공공기관의운영에관한법률","v":"FP","ev":"감독 범위 호별 명시+점검"},{"fid":"G-03-001@공익법인의설립ㆍ운영에관한법률","v":"FP","ev":"사유·시정·취소권 호별 명시"},{"fid":"G-03-001@공인회계사법","v":"BORDER","ev":"연수 자체감독, 협회 자율"},{"fid":"G-03-002@공인회계사법","v":"BORDER","ev":"보고·검사권 有, 주기 부재"},{"fid":"G-03-001@관세법","v":"FP","ev":"납세자보호위 심의구조 정비"},{"fid":"G-03-004@관세법","v":"FP","ev":"검사·시정명령권 호별 신설"},{"fid":"G-03-001@관세사법","v":"BORDER","ev":"연수 자체감독, 청장 승인"}],"new_signals":[{"name":"내부_지휘감독_FP","logic":"regex: (소속\\s*(직원|공무원|경찰관|대원)|소속을?\\s*지휘)\\s*[ㆍ·]?\\s*감독 OR (보좌|관장)하[고며].{0,15}지휘[ㆍ·]?감독","effect":"FP_FILTER","examples":["G-03-021@법원조직법","G-03-001@정부조직법","G-03-001@헌법재판소법","G-03-001@경찰직무응원법"],"rationale":"기관장이 부하직원을 통솔하는 내부 인사권 규정은 행정감독 결함이 아님. 입안길잡이상 정상 입법형식."},{"name":"위임사무_지휘감독_FP","logic":"regex: (위임|위탁|권한으로?\\s*(정한|규정한))\\s*사무.{0,30}지휘[ㆍ·]?감독 OR 위임.{0,20}받은\\s*자를?\\s*지휘","effect":"FP_FILTER","examples":["G-03-001@아시아문화중심도시조성에관한특별법","G-03-001@자동차관리법","G-03-002@화물자동차운수사업법"],"rationale":"위임자가 수임자를 감독하는 것은 행정권한위임위탁규정상 당연 수반사항."},{"name":"호별_감독범위_명시_FP","logic":"조문 내 '다음 각 호' 직후 감독 대상/사항 ≥3개 호 열거 AND 보고·검사·시정명령권 중 ≥2개 동시 규정","effect":"FP_FILTER","examples":["G-03-001@건설기계관리법","G-03-001@공공기관의운영에관한법률","G-03-004@관세법","G-03-001@공익법인의설립ㆍ운영에관한법률"],"rationale":"감독범위·방법·시정권이 호별로 구체화되어 있으면 룰 G-03의 5요건 중 핵심 3요건 충족."},{"name":"단문_외부감독_TP","logic":"조문 전체 길이 ≤80자 AND regex: ([X]장관|위원회|청장)이?\\s*감독한다\\.?$ AND 동일 조문 내 보고·검사·명령·시정 키워드 0개","effect":"TP_BOOST","examples":["G-03-001@생활체육진흥법","G-03-001@주택법","G-03-001@신용협동조합법"],"rationale":"외부기관에 대한 단문 감독선언만 두고 절차 전무한 경우가 권익위 규제개혁 기준상 전형적 결함."},{"name":"법원_사법감독_FP","logic":"regex: 법원이?\\s*감독한다 AND 같은 조 내 '검사인 선임|처분을 명할|이해관계인의 청구'","effect":"FP_FILTER","examples":["G-03-001@신탁법"],"rationale":"법원이 행하는 사법감독은 행정감독과 성격 상이, 직권·신청에 의한 처분권으로 절차 자체가 사법구조."},{"name":"벌칙조문_매칭_FP","logic":"regex: ^제\\d+조.{0,80}(징역|벌금|과태료|처한다)$ AND 룰 매칭 키워드 존재","effect":"FP_FILTER","examples":["G-03-001@항공안전법"],"rationale":"벌칙 조문에서 인용된 조항번호 매칭은 의미상 감독조항 아님."},{"name":"청산사무_한정감독_BORDER","logic":"regex: 청산\\s*사무를?\\s*감독한다","effect":"NEW_RULE","examples":["G-03-001@수산업협동조합법","G-03-001@신용협동조합법"],"rationale":"청산은 일회성·종결지향 절차로 일반 감독요건(주기·결과공개)이 부적합. 별도 분류 필요."},{"name":"보고검사권_부수_BORDER","logic":"감독한다 키워드 + 동일조 내 '보고|서류 제출|검사' 중 ≥2개 AND '주기|매년|정기|공개|시정명령' 0개","effect":"NEW_RULE","examples":["G-03-001@한국보훈복지의료공단법","G-03-001@경영지도사및기술지도사에관한법률","G-03-002@공인회계사법"],"rationale":"수단(보고·검사)은 있으나 절차(주기·공개·시정)가 결여된 중간형, BORDER 분류 권장."}],"missed_patterns":[{"name":"감독결과_미공개","logic":"감독한다 + 보고·검사권 有 + '공개|공표|국회보고' 키워드 0개","examples":["「한국보훈복지의료공단법」 §24","「공인회계사법」 §47","「관세법」 §327의2"]},{"name":"감독주기_부재","logic":"외부감독 조문에서 '매년|반기|분기|정기|연 \\d회' 부재","examples":["「상호저축은행법」 §22","「주택법」 §95","「공공기관의운영에관한법률」 §51"]},{"name":"시정명령_부재","logic":"감독한다 + 위반·부당 사실 발견시 시정·중지·취소 조항 부재","examples":["「생활체육진흥법」 §14","「상호저축은행법」 §22","「겨레말큰사전남북공동편찬사업회법」 §20"]},{"name":"감독수단_백지위임","logic":"감독한다 + 구체 수단 없이 '필요한 명령|필요한 조치|대통령령으로 정한다'만 규정","examples":["「상호저축은행법」 §22②","「정보통신진흥및융합활성화등에관한특별법」 §38의3⑦"]}]}