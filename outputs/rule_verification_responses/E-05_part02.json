"new_signals":[
{"name":"소송·형사 절차법 조문 FP필터","logic":"법령명에 '소송|형사|군사법원|형의집행' OR 조문제목에 '항소이유서|답변서|증인신문|송달|즉결심판' → 절차법 제재공백 FP","effect":"FP_FILTER","examples":["E-05-177@군사법원법","E-05-178@군사법원법","E-05-070@군사법원법","E-05-215@군사법원법"],"rationale":"소송절차 의무는 각하·실권 등 절차효과로 담보되어 벌칙 부재가 결함 아님."},
{"name":"협조요청 응답의무 FP필터","logic":"'협조를 요청할 수 있다' 다음 항에 '정당한 사유가 없으면 협조하여야|따라야' → 수익·협조의무 FP","effect":"FP_FILTER","examples":["E-05-046@국세기본법","E-05-032@농어촌정비법","E-05-019@군인의지위및복무에관한기본법"],"rationale":"협조요청에 대한 응답의무는 침익적 의무부과가 아니라 행정협력으로 제재대상 아님."},
{"name":"수익적 지급·보상 의무 FP필터","logic":"'지급하여야|보상하여야|이체하여야' AND 수범자가 공단·기금·지자체 AND 상대가 수급권자 → 수익적의무 FP","effect":"FP_FILTER","examples":["E-05-004@근로복지기본법","E-05-005@기초연금법","E-05-006@군인연금법","E-05-003@농업생산기반시설및주변지역활용에관한특별법"],"rationale":"국민에게 이익을 주는 급부의무는 미이행시 행정쟁송으로 다투며 벌칙 불요."},
{"name":"사인 표시·지정 의무 TP부스트","logic":"수범자가 사업자·개인 AND '지정하여야|등록을 하여야|가산하여 납부하여야' AND 조문내 벌칙연결 부재 → TP","effect":"TP_BOOST","examples":["E-05-004@대중문화예술산업발전법","E-05-001@김치산업진흥법","E-05-016@국세기본법"],"rationale":"사인에 대한 작위·표시 의무는 실효성 담보 위해 제재가 통상 수반되어 진정 공백 후보."}
],
"missed_patterns":[
{"name":"위임조항이 시행령에 이미 구체화됨(S-02)","logic":"본문 위임 AND 시행령 ±3조에 구체 호·절차 존재 시 FP다운그레이드","examples":["「국토의계획및이용에관한법률」 §90","「군인의지위및복무에관한기본법」 §41"]},
{"name":"이사회·내부거버넌스 의무 제재 부재","logic":"'이사회의 승인을 받아야|3분의 2 이상 찬성' 등 내부지배구조 의무인데 위반효과 미규정","examples":["「금융복합기업집단의감독에관한법률」 §15","「기술보증기금법」 §30"]}
]}
